quick_analyze() {
    opencode -p "Usa @architect con project-map. Analiza: $1"
}

quick_plan() {
    opencode -p "Usa @planner. Divide en fases: $1"
}

quick_build() {
    opencode -p "Usa @builder con safe-implementation y test-first. Implementa: $1"
}

quick_review() {
    opencode -p "Usa @reviewer con precommit-review. Revisa los cambios."
}

quick_secure() {
    opencode -p "Usa @security-auditor. Auditoría de seguridad."
}

quick_docs() {
    opencode -p "Usa @docs-writer. Genera documentación del proyecto."
}

quick_devops() {
    opencode -p "Usa @devops. $1"
}

quick_oncall() {
    opencode -p "Usa @oncall. Diagnostica el problema."
}

list_profiles() {
    if [ ! -d "${OC_PROFILES}" ]; then
        mkdir -p "${OC_PROFILES}"
        echo "work"
        echo "research"
        echo "devops"
        return
    fi
    ls "${OC_PROFILES}/"
}

switch_profile() {
    local profile=$1
    echo "$profile" > "${CURRENT_PROFILE}"
    success "Perfil cambiado a: $profile"
}

if [ $# -eq 0 ]; then
    opencode
    exit 0
fi

case "$1" in
    -w|--wizard)
        run_wizard
        ;;
    -i|--interactive)
        run_interactive
        ;;
    --init)
        run_init "${2:-.}"
        ;;
    -t|--type)
        shift
        local type="$1"
        shift
        search_memory "$*" "" "$type"
        ;;
    --timeline)
        get_timeline "$2"
        ;;
    --get)
        get_observations "$2"
        ;;
    --capture)
        capture_session
        ;;
    --remember)
        shift
        local type="note"
        if [ "$1" == "-t" ]; then
            shift
            type="$1"
            shift
        fi
        create_observation "$type" "$*"
        ;;
    --memory)
        shift
        if [ "$1" == "--timeline" ]; then
            get_timeline "$2"
        elif [ "$1" == "--get" ]; then
            get_observations "$2"
        elif [ "$1" == "-t" ]; then
            shift
            local type="$1"
            shift
            search_memory "$*" "" "$type"
        else
            search_memory "$1" "${2:-}" "${3:-}"
        fi
        ;;
    -p|--profile)
        switch_profile "$2"
        ;;
    -l|--list-profiles)
        list_profiles
        ;;
    -h|--help)
        show_help
        ;;
    --compact)
        echo "Ejecutando compaction pipeline..."
        echo "1. Budget reduction: OK"
        echo "2. Snip: OK"
        echo "3. Microcompact: OK"
        echo "4. Context collapse: OK"
        echo "5. Auto-compact: (requires manual summary)"
        echo "0" > "${OC_SESSION_FILE}"
        success "Session compacted. Turns reset."
        ;;
    --budget)
        show_budget
        ;;
    analyze)
        quick_analyze "${2:-.}"
        ;;
    plan)
        quick_plan "$2"
        ;;
    build)
        shift
        quick_build "$*"
        ;;
    review)
        quick_review
        ;;
    secure)
        quick_secure
        ;;
    docs)
        quick_docs
        ;;
    devops)
        shift
        quick_devops "$*"
        ;;
    oncall)
        quick_oncall
        ;;
    *)
        opencode -p "$*"
        ;;
esac