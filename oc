detect_stack() {
    local dir="${1:-.}"
    local stacks=()
    [ -f "${dir}/package.json" ]                                   && stacks+=("Node.js")
    { [ -f "${dir}/pyproject.toml" ] || [ -f "${dir}/requirements.txt" ]; } && stacks+=("Python")
    [ -f "${dir}/Cargo.toml" ]                                     && stacks+=("Rust")
    [ -f "${dir}/go.mod" ]                                         && stacks+=("Go")
    { [ -f "${dir}/pom.xml" ] || [ -f "${dir}/build.gradle" ]; }        && stacks+=("Java")
    { [ -f "${dir}/docker-compose.yml" ] || [ -f "${dir}/Dockerfile" ]; } && stacks+=("Docker")
    { [ -f "${dir}/terraform.tf" ] || [ -d "${dir}/.terraform" ]; }     && stacks+=("Terraform")
    printf '%s\n' "${stacks[@]}"
}

detect_test_commands() {
    local dir="${1:-.}"
    [ -f "${dir}/package.json" ] && grep -q '"test"' "${dir}/package.json" && echo "npm test"
    { [ -f "${dir}/pyproject.toml" ] || [ -f "${dir}/requirements.txt" ] || [ -f "${dir}/setup.py" ]; } && echo "pytest"
    [ -f "${dir}/Cargo.toml" ]                                              && echo "cargo test"
    [ -f "${dir}/go.mod" ]                                                  && echo "go test ./..."
    [ -f "${dir}/Makefile" ] && grep -q "^test:" "${dir}/Makefile"          && echo "make test"
}

run_init() {
    local target_dir="${1:-.}"
    local opencode_dir="${target_dir}/.opencode"

    if [ -d "${opencode_dir}" ]; then
        warn "Ya existe ${opencode_dir}/"
        read -rp "Sobrescribir? [y/n]: " confirm
        [[ "$confirm" != "y" ]] && exit 0
        rm -rf "${opencode_dir}"
    fi

    info "Creando estructura de proyecto..."
    mkdir -p "${opencode_dir}"/{agents,skills,mcp,hooks}

    cat > "${opencode_dir}/opencode.json" << 'EOF'
{
  "$schema": "https://opencode.ai/config.json",
  "extends": "~/.config/opencode/opencode.json",
  "project": {
    "name": "",
    "stack": [],
    "entrypoints": []
  },
  "agents": {
    "project": "./agents"
  }
}
EOF

    # Detect stack and test commands
    local detected_stacks
    detected_stacks=$(detect_stack "$target_dir")
    local detected_tests
    detected_tests=$(detect_test_commands "$target_dir")

    if [ -n "$detected_stacks" ]; then
        info "Stack detectado: $(echo "$detected_stacks" | tr '\n' ' ')"
    fi

    # Generate CLAUDE.md with detected context
    {
        echo "# Project Context"
        echo ""
        echo "## Description"
        echo "Describe the project here."
        echo ""
        if [ -n "$detected_stacks" ]; then
            echo "## Detected Stack"
            while IFS= read -r stack; do
                echo "- $stack"
            done <<< "$detected_stacks"
            echo ""
        else
            echo "## Stack"
            echo "- ..."
            echo ""
        fi
        echo "## Commands"
        echo '```bash'
        if [ -n "$detected_tests" ]; then
            while IFS= read -r cmd; do
                echo "$cmd"
            done <<< "$detected_tests"
        else
            echo "# add test, lint, build commands here"
        fi
        echo '```'
        echo ""
        echo "## Notes"
        echo "- Project-specific configuration"
        echo "- Team conventions"
        echo "- Do not modify .env files"
    } > "${opencode_dir}/CLAUDE.md"

    if [ -d "${target_dir}/.git" ]; then
        mkdir -p "${target_dir}/.git/hooks"
        cat > "${target_dir}/.git/hooks/pre-commit" << 'HOOK'
#!/bin/bash

echo ""
echo "🔍 OpenCode Pre-Commit Review"
echo "=============================="

tmp_output=$(mktemp)
trap 'rm -f "$tmp_output"' EXIT

diff_context=$(git diff --cached --stat && printf '\n' && git diff --cached --)
if [ -z "$diff_context" ]; then
    diff_context="No hay diff staged disponible. Revisa el estado Git si aplica."
fi

if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --verbose; then
        echo ""
        echo "❌ Pre-commit rechazado. gitleaks detectó posibles secretos."
        exit 1
    fi
fi

prompt="Ejecuta @reviewer con precommit-review. Revisa los archivos modificados. No modifiques nada.

Diff staged:
$diff_context

Termina con una línea exacta:
BLOCKING_FINDINGS=true
o
BLOCKING_FINDINGS=false"

if command -v oc >/dev/null 2>&1; then
    oc "$prompt" | tee "$tmp_output"
    status=${PIPESTATUS[0]}
else
    opencode run "$prompt" | tee "$tmp_output"
    status=${PIPESTATUS[0]}
fi

if [ "$status" -ne 0 ] || grep -Eq '^BLOCKING_FINDINGS=true$|^RECOMMENDATION=CORRECT$' "$tmp_output"; then
    echo ""
    echo "❌ Pre-commit rechazado. Corrige los errores antes de commitir."
    exit 1
fi

if ! grep -Eq '^BLOCKING_FINDINGS=false$' "$tmp_output"; then
    echo ""
    echo "❌ Pre-commit rechazado. Falta marcador BLOCKING_FINDINGS=false."
    exit 1
fi

echo ""
echo "✅ Pre-commit aprobado"
HOOK
        chmod +x "${target_dir}/.git/hooks/pre-commit"
        success "Git hook configurado en ${target_dir}/.git/hooks/pre-commit"
        cat > "${target_dir}/.git/hooks/pre-push" << 'HOOK'
#!/bin/bash

echo ""
