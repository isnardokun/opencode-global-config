# Find project root by walking up for .git
find_project_root() {
    local dir="${1:-$(pwd)}"
    while [ "$dir" != "/" ] && [ -n "$dir" ]; do
        [ -d "${dir}/.git" ] && printf '%s' "$dir" && return 0
        dir=$(dirname "$dir")
    done
    return 1
}

check_fzf() {
    if ! command -v fzf >/dev/null 2>&1; then
        error "fzf required for interactive mode. Install: dnf install fzf"
    fi
}

# Auto-detect project from current directory.
# Uses git remote or directory basename as project identifier.
detect_project() {
    local cwd="${1:-$(pwd)}"

    # Check for .git to identify project root
    if [ -d "${cwd}/.git" ]; then
        # Try to get project name from git remote
        local remote_url=$(git -C "$cwd" remote get-url origin 2>/dev/null || true)
        if [ -n "$remote_url" ]; then
            # Extract last path component from git URL
            local project_name=$(printf '%s' "$remote_url" | sed 's/.*\///' | sed 's/\.git$//')
            [ -n "$project_name" ] && printf '%s' "$project_name" && return 0
        fi
        # Fallback: use directory name
        basename "$cwd" && return 0
    fi

    # Walk up to find .git parent
    local dir="$cwd"
    while [ "$dir" != "/" ] && [ "$dir" != "." ] && [ -n "$dir" ]; do
        if [ -d "${dir}/.git" ]; then
            basename "$dir" && return 0
        fi
        dir=$(dirname "$dir")
    done

    # Default fallback
    printf '%s' "global"
}

# Auto-compact: compact session if turns exceed threshold
auto_compact_if_needed() {
    [ "${OC_AUTO_COMPACT_RUNNING:-0}" = "1" ] && return 0

    local turns=0
    [ -f "${OC_SESSION_FILE}" ] && turns=$(cat "${OC_SESSION_FILE}" 2>/dev/null || echo 0)

    if [ "${turns:-0}" -gt 20 ]; then
        info "Auto-compacting session (${turns} turns)..."
        local OC_AUTO_COMPACT_RUNNING=1
        if _oc_run -p "Summarize this entire session in a structured markdown document with these sections:
## Goal
What was the main task or objective?

## Findings
Key things discovered or analyzed (file paths, functions, issues found).

## Changes Made
Every file modified or created, with a one-line description of what changed and why.

## Decisions
Technical decisions made and the reasoning behind each.

## Current State
What is the state of the project/task right now?

## Remaining Work
What has not been done yet, if anything?

Keep all technical details. Output as plain markdown." 2>/dev/null; then
            echo "0" > "${OC_SESSION_FILE}"
            success "Session auto-compacted. Turn counter reset."
        fi
    fi
}

# Auto-reflect: create observation after workflow completion (non-interactive)
auto_reflect() {
    local workflow="$1"
    local target="$2"
    local project
    project=$(detect_project "$target")

    local turns=0
    [ -f "${OC_SESSION_FILE}" ] && turns=$(cat "${OC_SESSION_FILE}" 2>/dev/null || echo 0)

    local template=""
    case "$workflow" in
        bug-hunt)
            template="Bug hunt completado en ${project}. Turns: ${turns}."
            ;;
        new-project)
            template="Nuevo proyecto inicializado: ${project}. Turns: ${turns}."
            ;;
        debug)
            template="Debug completado en ${project}. Turns: ${turns}."
            ;;
        document)
            template="Documentación generada para ${project}. Turns: ${turns}."
            ;;
        feature)
            template="Feature implementada en ${project}. Turns: ${turns}."
            ;;
        *)
            template="Workflow ${workflow} completado en ${project}. Turns: ${turns}."
            ;;
    esac

    create_observation "note" "$template" "$project"
}

# Analyze patterns from outcomes and suggest improvements (non-interactive)
analyze_outcomes() {
    local outcome_dir="${OC_MEMORY}/outcomes"
    [ ! -d "$outcome_dir" ] && return 0

    local failure_count=0

    while IFS= read -r -d '' f; do
        local content=$(cat "$f" 2>/dev/null || echo "{}")
        if echo "$content" | grep -q '"failure"'; then
            failure_count=$((failure_count + 1))
        fi
    done < <(find "$outcome_dir" -name "*.json" -mtime -7 -print0 2>/dev/null)

    if [ "$failure_count" -ge 3 ]; then
        warn "Detected ${failure_count} workflow failures in recent history"
        info "Pattern detected. Consider documenting in memory:"
        echo "  oc --remember -t decision 'workflow failure pattern: ...'"
    fi
}

show_status() {
    local turns=0
    [ -f "${OC_SESSION_FILE}" ] && turns=$(cat "${OC_SESSION_FILE}")

    profile=$(get_active_profile 2>/dev/null || echo "default")
    [ -z "$profile" ] && profile="none"

    local project
    project=$(detect_project "$(pwd)")

    local hooks_dir="${HOME}/.config/opencode/hooks"
    if [ -f "${hooks_dir}/pre-commit" ] && [ -f "${hooks_dir}/pre-push" ]; then
        hook_installed="✅ installed (pre-commit + pre-push)"
    else
        hook_installed="❌ not installed"
    fi

    local last_cmd=""
    if [ -f "${OC_MEMORY}/.last_obs_id" ]; then
        last_cmd=$(cat "${OC_MEMORY}/.last_obs_id" 2>/dev/null || echo "none")
    fi

    echo ""
    echo "=== OpenCode Status ==="
    echo "Session turns: ${turns}"
    echo "Active profile: ${profile}"
    echo "Current project: ${project}"
    echo "Hooks: ${hook_installed}"
    echo "Last observation: ${last_cmd}"
    echo ""
    echo "Recent memory entries:"
    if [ -f "${OC_MEMORY}/index.jsonl" ]; then
        tail -5 "${OC_MEMORY}/index.jsonl" 2>/dev/null | while IFS= read -r line; do
            echo "  $line"
        done
    else
        echo "  (no entries)"
    fi
    echo ""
    if [ "$turns" -gt 20 ]; then
        echo "⚠️  Auto-compact will trigger at 20 turns (or use: oc --compact)"
    fi
}

