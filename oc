    printf '%s\n' \
        "a  @architect    - Analizar arquitectura y riesgos" \
        "p  @planner      - Planificar tarea en fases" \
        "b  @builder      - Implementar cambios" \
        "r  @reviewer     - Revisar código" \
        "s  @security     - Auditoría de seguridad" \
        "d  @docs         - Generar documentación" \
        "v  @devops       - Tareas DevOps" \
        "o  @oncall       - Diagnosticar producción" \
        "w  Wizard        - Modo guiado paso a paso" \
        "i  Init          - Inicializar proyecto" \
        "m  Memory        - Buscar en memoria" \
        "q  Quit"
}

run_agent() {
    local agent="$1"
    local task="$2"
    _oc_run -p "Usa el agente @${agent}. $task"
}

run_wizard() {
    echo -e "${BLUE}=== Modo Wizard - Paso a Paso ===${NC}"
    echo ""
    echo "Selecciona el tipo de tarea:"
    echo "1) Analizar proyecto (architecture + risks)"
    echo "2) Planificar tarea compleja"
    echo "3) Implementar nuevo feature"
    echo "4) Revisar código existente"
    echo "5) Auditoría de seguridad"
    echo "6) DevOps (Docker, CI/CD, etc)"
    echo ""

    read -rp "Opción [1-6]: " option
    echo ""

    case $option in
        1)
            read -rp "Ruta del proyecto: " path
            echo ""
            info "Fase 1: @architect + project-map"
            _oc_run -p "Usa @architect con project-map. Analiza: $path"
            echo ""
            read -rp "Continuar a planificación? [y/n]: " cont
            if [[ "$cont" == "y" ]]; then
                echo ""
                info "Fase 2: @planner"
                _oc_run -p "Usa @planner. Divide en fases verificables esta tarea: análisis de $path"
            fi
            ;;
        2)
            read -rp "Describe la tarea: " task
            echo ""
            info "Fase 1: @planner"
            _oc_run -p "Usa @planner. Divide esta tarea en fases: $task"
            echo ""
            read -rp "Continuar a implementación? [y/n]: " cont
            if [[ "$cont" == "y" ]]; then
                echo ""
                info "Fase 2: @builder"
                _oc_run -p "Usa @builder con safe-implementation y test-first. Implementa: $task"
            fi
            ;;
        3)
            read -rp "Descripción del feature: " feature
            echo ""
            info "Fase 1: @architect"
            _oc_run -p "Usa @architect. Analiza el proyecto actual para implementar: $feature"
            echo ""
            info "Fase 2: @planner"
            _oc_run -p "Usa @planner. Planifica la implementación de: $feature"
            echo ""
            info "Fase 3: @builder"
            _oc_run -p "Usa @builder con safe-implementation y test-first. Implementa: $feature"
            echo ""
            info "Fase 4: @reviewer"
            _oc_run -p "Usa @reviewer con precommit-review. Revisa los cambios."
            ;;
        4)
            read -rp "Archivos a revisar: " files
            echo ""
            info "Fase 1: @reviewer"
            _oc_run -p "Usa @reviewer. Revisa: $files"
            echo ""
            read -rp "Ejecutar auditoría de seguridad? [y/n]: " sec
            if [[ "$sec" == "y" ]]; then
                echo ""
                info "Fase 2: @security-auditor"
                _oc_run -p "Usa @security-auditor. Busca vulnerabilidades en: $files"
            fi
            ;;
        5)
            read -rp "Ruta a auditar: " path
            echo ""
            info "Fase 1: @security-auditor"
            _oc_run -p "Usa @security-auditor. Auditoría completa de: $path"
            ;;
        6)
            read -rp "Descripción tarea DevOps: " task
            echo ""
            info "Fase 1: @devops"
            _oc_run -p "Usa @devops. $task"
            ;;
    esac
}

detect_stack() {
    local dir="${1:-.}"
    local stacks=()
    [ -f "${dir}/package.json" ]                                   && stacks+=("Node.js")
    [ -f "${dir}/pyproject.toml" ] || [ -f "${dir}/requirements.txt" ] && stacks+=("Python")
    [ -f "${dir}/Cargo.toml" ]                                     && stacks+=("Rust")
    [ -f "${dir}/go.mod" ]                                         && stacks+=("Go")
    [ -f "${dir}/pom.xml" ] || [ -f "${dir}/build.gradle" ]        && stacks+=("Java")
    [ -f "${dir}/docker-compose.yml" ] || [ -f "${dir}/Dockerfile" ] && stacks+=("Docker")
    [ -f "${dir}/terraform.tf" ] || [ -d "${dir}/.terraform" ]     && stacks+=("Terraform")
    printf '%s\n' "${stacks[@]}"
}

detect_test_commands() {
    local dir="${1:-.}"
    [ -f "${dir}/package.json" ] && grep -q '"test"' "${dir}/package.json" && echo "npm test"
    [ -f "${dir}/pyproject.toml" ] || [ -f "${dir}/setup.py" ]             && echo "pytest"
    [ -f "${dir}/Cargo.toml" ]                                              && echo "cargo test"
    [ -f "${dir}/go.mod" ]                                                  && echo "go test ./..."
    [ -f "${dir}/Makefile" ] && grep -q "^test:" "${dir}/Makefile"          && echo "make test"
}

run_init() {
    local target_dir="${1:-.}"
    local opencode_dir="${target_dir}/.opencode"

    if [ -d "${opencode_dir}" ]; then
        warn "Ya existe ${opencode_dir}/"
        read -rp "Sobrescribir? [y/n]: " confirm
        [[ "$confirm" != "y" ]] && exit 0
        rm -rf "${opencode_dir}"
    fi

    info "Creando estructura de proyecto..."
    mkdir -p "${opencode_dir}"/{agents,skills,mcp,hooks}
    mkdir -p "${target_dir}/.git/hooks"

    cat > "${opencode_dir}/opencode.json" << 'EOF'
{
  "$schema": "https://opencode.ai/config.json",
  "extends": "~/.config/opencode/opencode.json",
  "project": {
    "name": "",
    "stack": [],
    "entrypoints": []
  },
  "agents": {
    "project": "~/.opencode/agents"
  }
}
EOF

    # Detect stack and test commands
    local detected_stacks
    detected_stacks=$(detect_stack "$target_dir")
    local detected_tests
    detected_tests=$(detect_test_commands "$target_dir")

    if [ -n "$detected_stacks" ]; then
        info "Stack detectado: $(echo "$detected_stacks" | tr '\n' ' ')"
    fi

    # Generate CLAUDE.md with detected context
    {
        echo "# Project Context"
        echo ""
        echo "## Description"
        echo "Describe the project here."
        echo ""
        if [ -n "$detected_stacks" ]; then
            echo "## Detected Stack"
            while IFS= read -r stack; do
                echo "- $stack"
            done <<< "$detected_stacks"
            echo ""
        else
            echo "## Stack"
            echo "- ..."
            echo ""
        fi
        echo "## Commands"
        echo '```bash'
        if [ -n "$detected_tests" ]; then
            while IFS= read -r cmd; do
                echo "$cmd"
            done <<< "$detected_tests"
        else
            echo "# add test, lint, build commands here"
        fi
        echo '```'
        echo ""
        echo "## Notes"
        echo "- Project-specific configuration"
        echo "- Team conventions"
        echo "- Do not modify .env files"
    } > "${opencode_dir}/CLAUDE.md"

    cat > "${target_dir}/.git/hooks/pre-commit" << 'HOOK'
#!/bin/bash
echo "Ejecutando revisión pre-commit..."
opencode run "Ejecuta @reviewer con precommit-review. Revisa los archivos modificados. No modifiques nada."
HOOK
    chmod +x "${target_dir}/.git/hooks/pre-commit"

    success "Proyecto inicializado en ${opencode_dir}/"
    success "Git hook configurado en ${target_dir}/.git/hooks/pre-commit"
}

run_interactive() {
    check_fzf
    local choice
    choice=$(show_menu | fzf --height=14 --border --prompt="Selecciona: " | awk '{print $1}')

    case "$choice" in
        a) run_agent "architect" "Analiza el proyecto actual sin modificar" ;;
        p)
            read -rp "Tarea: " task
            run_agent "planner" "Divide esta tarea en fases: $task"
            ;;
        b)
            read -rp "Cambio a implementar: " cambio
            run_agent "builder" "Implementa este cambio: $cambio"
            ;;
        r) run_agent "reviewer" "Revisa los cambios realizados" ;;
        s) run_agent "security-auditor" "Audita seguridad del proyecto actual" ;;
        d) run_agent "docs-writer" "Genera/actualiza documentación del proyecto" ;;
        v)
            read -rp "Descripción DevOps: " desc
            run_agent "devops" "Tarea DevOps: $desc"
            ;;
        o) run_agent "oncall" "Diagnostica problema en producción" ;;
        w) run_wizard ;;
        i) run_init "$(pwd)" ;;
        m)
            read -rp "Query: " query
            search_memory "$query"
            ;;
        q) exit 0 ;;
    esac
}

