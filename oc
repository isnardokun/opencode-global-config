#!/usr/bin/env bash

OC_CONFIG="${HOME}/.config/opencode"
OC_BIN="${HOME}/.local/bin"
OC_MEMORY="${OC_CONFIG}/memory"
OC_PROFILES="${OC_CONFIG}/profiles"
CURRENT_PROFILE="${OC_CONFIG}/.current_profile"

OC_BUDGET_FILE="${OC_CONFIG}/.budget"
OC_SESSION_FILE="${OC_CONFIG}/.session"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[OK]${NC} $1"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $1"; }
error()   { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

track_turn() {
    local turns=1
    if [ -f "${OC_SESSION_FILE}" ]; then
        turns=$(($(cat "${OC_SESSION_FILE}") + 1))
    fi
    echo "$turns" > "${OC_SESSION_FILE}"
    if [ "$turns" -gt 20 ]; then
        warn "Session turns: $turns (consider context compaction)"
    fi
}

check_budget() {
    local turns=0
    [ -f "${OC_SESSION_FILE}" ] && turns=$(cat "${OC_SESSION_FILE}")
    if [ "$turns" -gt 50 ]; then
        warn "High session turns ($turns). Context may need compaction."
    fi
}

# Only require opencode at startup; fzf checked on demand
check_deps() {
    if ! command -v opencode >/dev/null 2>&1; then
        error "opencode not found. Install from https://opencode.ai"
    fi
}

check_fzf() {
    if ! command -v fzf >/dev/null 2>&1; then
        error "fzf required for interactive mode. Install: dnf install fzf"
    fi
}

show_budget() {
    local turns=0
    [ -f "${OC_SESSION_FILE}" ] && turns=$(cat "${OC_SESSION_FILE}")
    echo "Session turns: $turns"
    [ "$turns" -gt 20 ] && echo "Consider running: oc --compact"
}

# Real entropy: od is POSIX — works on Linux and macOS without xxd
generate_obs_id() {
    local rand
    rand=$(od -An -N4 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n\t') \
        || rand=$(printf '%08x' $(( (RANDOM << 16) | RANDOM )))
    printf '%s-%s' "$(date +%Y%m%d-%H%M%S)" "$rand"
}

create_observation() {
    local type="${1:-note}"
    local content="$2"
    local project="${3:-global}"
    local obs_id
    obs_id=$(generate_obs_id)

    if [ -z "$content" ]; then
        echo "Error: content is required"
        return 1
    fi

    local obs_dir="${OC_MEMORY}/projects/${project}"
    mkdir -p "$obs_dir"

    local obs_file="${obs_dir}/${obs_id}.md"

    cat > "$obs_file" << EOF
---
id: obs_${obs_id}
date: $(date +%Y-%m-%d\ %H:%M:%S)
project: ${project}
type: ${type}
summary: ${content:0:100}
tokens_est: 200
---

${content}
EOF

    echo "$obs_id" > "${OC_MEMORY}/.last_obs_id"
    success "Observation created: obs_${obs_id}"

    # Append to markdown INDEX
    if grep -q "^<!-- INDEX_START -->" "${OC_MEMORY}/INDEX.md" 2>/dev/null; then
        echo "obs_${obs_id} | $(date +%Y-%m-%d) | ${project} | ${type} | ${content:0:80}" >> "${OC_MEMORY}/INDEX.md"
    fi

    # Append to JSONL index for fast querying with jq/fzf/ripgrep
    local jsonl_index="${OC_MEMORY}/index.jsonl"
    printf '{"id":"obs_%s","date":"%s","project":"%s","type":"%s","summary":"%s","path":"%s"}\n' \
        "$obs_id" \
        "$(date +%Y-%m-%dT%H:%M:%S)" \
        "$project" \
        "$type" \
        "$(printf '%s' "${content:0:100}" | sed 's/"/\\"/g')" \
        "memory/projects/${project}/${obs_id}.md" \
        >> "$jsonl_index"
}

search_memory() {
    local query="${1:-}"
    local project="${2:-}"
    local type="${3:-}"

    if [ -z "$query" ]; then
        echo "Usage: oc --memory <query> [-p project] [-t type]"
        return 0
    fi

    if [ ! -f "${OC_MEMORY}/INDEX.md" ]; then
        warn "No memory index found. Use oc --remember to add observations."
        return 0
    fi

    local results
    results=$(grep -i "$query" "${OC_MEMORY}/INDEX.md" 2>/dev/null | head -20)

    if [ -z "$results" ]; then
        echo "No results found for: $query"
        return 0
    fi

    echo -e "${BLUE}=== Memory Search Results ===${NC}"
    while IFS= read -r line; do
        echo "$line"
    done <<< "$results"
    echo ""
    echo "Use --timeline <obs_id> for context or --get <id1,id2> for full details."
}

get_observations() {
    local ids="${1:-}"

    if [ -z "$ids" ]; then
        echo "Usage: oc --get <obs_id1,obs_id2,...>"
        return 0
    fi

    IFS=',' read -ra OBS_IDS <<< "$ids"

    for obs_id in "${OBS_IDS[@]}"; do
        obs_id=$(echo "$obs_id" | tr -d ' ')
        local obs_file
        obs_file=$(find "${OC_MEMORY}" -name "${obs_id}.md" 2>/dev/null | head -1)

        if [ -z "$obs_file" ]; then
            warn "Observation not found: $obs_id"
            continue
        fi

        echo -e "${BLUE}=== obs_${obs_id} ===${NC}"
        cat "$obs_file"
        echo ""
    done
}

get_timeline() {
    local obs_id="${1:-}"

    if [ -z "$obs_id" ]; then
        echo "Usage: oc --timeline <obs_id>"
        return 0
    fi

    local obs_file
    obs_file=$(find "${OC_MEMORY}" -name "${obs_id}.md" 2>/dev/null | head -1)

    if [ -z "$obs_file" ]; then
        warn "Observation not found: $obs_id"
        return 0
    fi

    local obs_dir
    obs_dir=$(dirname "$obs_file")

    echo -e "${BLUE}=== Timeline around $obs_id ===${NC}"
    while IFS= read -r f; do
        local fname summary fdate
        fname=$(basename "$f" .md)
        summary=$(grep "^summary:" "$f" 2>/dev/null | cut -d':' -f2 | tr -d ' ')
        fdate=$(grep "^date:" "$f" 2>/dev/null | cut -d':' -f2 | tr -d ' ')
        echo "$fname | $fdate | ${summary:0:80}"
    done < <(ls -t "$obs_dir"/*.md 2>/dev/null | head -5)
}

capture_session() {
    info "Session started: $(date)"
    info "Project: ${PWD}"
    mkdir -p "${OC_MEMORY}"
    {
        echo "---"
        echo "Session: $(date)"
        echo "Directory: ${PWD}"
    } >> "${OC_MEMORY}/sessions.log"
}

get_active_profile() {
    [ -f "${CURRENT_PROFILE}" ] && cat "${CURRENT_PROFILE}"
}

switch_profile() {
    local profile="$1"
    echo "$profile" > "${CURRENT_PROFILE}"
    export OPENCODE_PROFILE="$profile"
    success "Perfil: $profile"
}

# Read profile rules JSON and emit them as LLM instruction text.
# This is how profile constraints become real: we inject them into
# every prompt so the model sees them as explicit requirements.
get_profile_rules() {
    local profile profile_file
    profile=$(get_active_profile)
    [ -z "$profile" ] && return 0
    profile_file="${OC_PROFILES}/${profile}.json"
    [ ! -f "$profile_file" ] && return 0

    python3 - "$profile_file" << 'PYEOF'
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
except Exception:
    sys.exit(0)
rules = data.get("policy", data.get("rules", {}))
lines = []
if rules.get("reportOnly"):
    lines.append("- Do NOT make any file edits or run commands. Report findings only.")
if rules.get("requireExplanation"):
    lines.append("- Before any change, explain exactly what you will do and why.")
if rules.get("requireDiffReview"):
    lines.append("- Show a summary/diff of all changes before applying them.")
if rules.get("requireTests"):
    lines.append("- Write or update tests before implementing any change.")
if rules.get("checkpointBeforeChanges"):
    lines.append("- Create a summary of current state before making changes.")
if rules.get("requireCheckpoint"):
    lines.append("- Create a state checkpoint before any change.")
if rules.get("requireRollback"):
    lines.append("- Always provide a rollback plan before making any change.")
if rules.get("requireSecurityReview"):
    lines.append("- Include a security review for every change (injection, auth, secrets, permissions).")
if rules.get("trackDecisions"):
    lines.append("- Document every technical decision with its reasoning.")
if rules.get("documentAllChanges"):
    lines.append("- Document every change you make with what was changed and why.")
if rules.get("allowEnvEdit") is False:
    lines.append("- Never modify .env files or any environment configuration files.")
max_files = rules.get("maxFilesPerIteration")
if max_files and isinstance(max_files, int) and max_files > 0:
    lines.append(f"- Limit changes to at most {max_files} files per iteration.")
if lines:
    print("\n\n[Active profile rules — follow these strictly:]\n" + "\n".join(lines))
PYEOF
}

# Inject active profile rules into every non-interactive opencode run.
_oc_run() {
    local profile rules_text
    profile=$(get_active_profile)
    rules_text=$(get_profile_rules)

    # Internal wrapper calls use the historical "-p <prompt>" form. OpenCode
    # 1.14 uses `opencode run <message>` for non-interactive prompts.
    if [ "${1:-}" = "-p" ] && [ $# -gt 1 ]; then
        local prompt="$2"
        shift 2
        opencode run "${prompt}${rules_text}" "$@"
    else
        opencode "$@"
    fi
}

check_deps
track_turn

