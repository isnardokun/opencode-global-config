ask_route() {
    local task="$1"
    local lower intent route prompt
    lower=$(printf '%s' "$task" | tr '[:upper:]' '[:lower:]')

    local guardrail="Si falta información crítica, haz primero hasta 3 preguntas puntuales y espera respuesta antes de modificar o ejecutar acciones riesgosas."

    if [[ "$lower" =~ (100%|readiness|release.?ready|release.?readiness|falta|pendiente|brecha|brechas) ]]; then
        intent="readiness-analysis"
        route="@architect + project-map -> @planner"
        prompt="Usa @architect con project-map en modo solo lectura para evaluar readiness técnico del proyecto. No modifiques archivos. Evita bash salvo que el usuario lo apruebe; usa lectura, glob y grep cuando sea suficiente. Luego usa @planner para proponer fases verificables hacia 100%. $guardrail Solicitud: $task"
    elif [[ "$lower" =~ (implementa|crea|agrega|add|build|feature) ]] && [[ "$lower" =~ (auth|autenticaci[oó]n|login) ]] && ! [[ "$lower" =~ (jwt|oauth|saml|passkey|session|sesi[oó]n|sesiones|cookie|2fa|mfa) ]]; then
        intent="clarify"
        route="interpreter -> ask clarifying questions"
        prompt=$(ask_prompt_for_route "$task" "$intent" "$route")
    elif [[ "$lower" =~ (prod|producci[oó]n|crash|ca[ií]do|logs?|incidente|oncall) ]]; then
        intent="production-debug"
        route="@oncall -> @builder -> @security-auditor"
        prompt="Usa @oncall para diagnosticar. $guardrail Si hay fix claro, planifica mitigación reversible y luego usa @builder con safe-implementation/test-first; finaliza con @security-auditor. Solicitud: $task"
    elif [[ "$lower" =~ (seguridad|security|vulnerab|audit|audita|auditar|auditor[ií]a|secret|token|credencial|xss|sql) ]]; then
        intent="security-review"
        route="@security-auditor + rubrics/security-review.md"
        prompt="Usa @security-auditor y aplica la security review rubric: hallazgos verificados, severidad, file:line, remediación y riesgos residuales. $guardrail Solicitud: $task"
    elif [[ "$lower" =~ (review|revisa|verifica|check|pre.?commit|diff|c[oó]digo) ]]; then
        intent="code-review"
        route="@reviewer + precommit-review + rubrics/code-review.md"
        prompt="Usa @reviewer con precommit-review y aplica la code review rubric: bloqueantes, recomendaciones importantes, mejoras opcionales y aprobación explícita. $guardrail Solicitud: $task"
    elif [[ "$lower" =~ (doc|docs|documenta|readme|changelog|manual) ]]; then
        intent="documentation"
        route="@docs-writer -> @reviewer"
        prompt="Usa Docs-First: primero @architect con project-map para revisar docs/ existente y código real; luego @docs-writer para crear/actualizar docs/ como contexto vivo del proyecto; finalmente @reviewer para revisar consistencia. Incluye PROJECT_CONTEXT, BUSINESS_LOGIC, DATA_STRUCTURE, ARCHITECTURE, DECISIONS, CHANGELOG, CONVERSATION, TASKS, RISKS y ONBOARDING según aplique. No inventes features ni reglas de negocio. $guardrail Solicitud: $task"
    elif [[ "$lower" =~ (docker|ci/cd|cicd|deploy|kubernetes|terraform|infra|pipeline|devops) ]] || [[ "$lower" =~ (^|[[:space:]])ci([[:space:]]|$) ]] || [[ "$lower" =~ (^|[[:space:]])cd([[:space:]]|$) ]]; then
        intent="devops"
        route="@devops"
        prompt="Usa @devops. $guardrail Diseña cambios reversibles, valida comandos y considera rollback. Solicitud: $task"
    elif [[ "$lower" =~ (plan|planifica|diseña|dise[ñn]ar|c[oó]mo|fases) ]]; then
        intent="planning"
        route="@planner + rubrics/plan-review.md"
        prompt="Usa @planner y aplica la plan review rubric: fases verificables, supuestos, riesgos, tradeoffs y criterios de éxito. $guardrail Solicitud: $task"
    elif [[ "$lower" =~ (analiza|analyze|arquitectura|estructura|stack|entender) ]]; then
        intent="architecture-analysis"
        route="@architect + project-map"
        prompt="Usa @architect con project-map. $guardrail Analiza stack, entrypoints, módulos críticos, riesgos, seguridad visible, comandos y plan sugerido. Solicitud: $task"
    elif [[ "$lower" =~ (bug|fix|arregla|corrige|error|falla|failing|broken) ]]; then
        intent="bugfix"
        route="@architect -> @planner -> @builder -> @reviewer"
        prompt="Usa flujo bugfix con Docs-First: revisa docs/ existente antes de diagnosticar; si falta docs/ o está desactualizado, reporta el gap y crea/actualiza solo lo necesario para contexto. $guardrail @architect para causa probable, @planner con criterios verificables, @builder con safe-implementation/test-first, y @reviewer con precommit-review. Solicitud: $task"
    elif [[ "$lower" =~ (implementa|crea|agrega|add|build|feature|mejora|cambia|modifica) ]]; then
        intent="feature"
        route="@architect -> @planner -> @builder -> @reviewer"
        prompt="Usa flujo feature con Docs-First: antes de diseñar o editar, revisa docs/ como fuente de contexto; si es proyecto nuevo o faltan datos críticos, pregunta primero; si no existe docs/, crea/propon documentación inicial mínima. $guardrail @architect para contexto, @planner aplicando plan review rubric, @builder con safe-implementation/test-first, y @reviewer aplicando code review rubric. Solicitud: $task"
    else
        intent="clarify"
        route="interpreter -> ask clarifying questions"
        prompt=$(ask_prompt_for_route "$task" "$intent" "$route")
    fi

    printf '%s\n%s\n%s\n' "$intent" "$route" "$prompt"
}

ask_command() {
    local dry_run=0 explain=0 clarify=0
    local args=()

    shift
    while [ $# -gt 0 ]; do
        case "$1" in
            --dry-run) dry_run=1 ;;
            --explain) explain=1 ;;
            --clarify) clarify=1 ;;
            -h|--help) ask_usage; return 0 ;;
            *) args+=("$1") ;;
        esac
        shift || true
    done

    if [ "${#args[@]}" -eq 0 ]; then
        ask_usage
        return 1
    fi

    [ "$dry_run" -eq 1 ] && clarify=0

    local task="${args[*]}"
    if [ "$clarify" -eq 1 ]; then
        local answer
        read -rp "Objetivo concreto: " answer
        [ -n "$answer" ] && task="$task | Objetivo: $answer"
        read -rp "Ruta/archivo/proyecto relevante (opcional): " answer
        [ -n "$answer" ] && task="$task | Contexto: $answer"
        read -rp "Restricciones o criterios de éxito (opcional): " answer
        [ -n "$answer" ] && task="$task | Criterios: $answer"
    fi

    local route_output intent route prompt
    route_output=$(ask_route "$task")
    intent=$(printf '%s\n' "$route_output" | sed -n '1p')
    route=$(printf '%s\n' "$route_output" | sed -n '2p')
    prompt=$(printf '%s\n' "$route_output" | sed '1,2d')

    if [ "$dry_run" -eq 1 ] || [ "$explain" -eq 1 ]; then
        echo "Intent: $intent"
        echo "Route: $route"
        echo "Prompt:"
        printf '%s\n' "$prompt"
    fi

    [ "$dry_run" -eq 1 ] && return 0
    _oc_run -p "$prompt"
}

