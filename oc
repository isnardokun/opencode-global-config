ask_route() {
    local task="$1"
    local lower intent route prompt
    lower=$(printf '%s' "$task" | tr '[:upper:]' '[:lower:]')

    local guardrail="Si falta información crítica, haz primero hasta 3 preguntas puntuales y espera respuesta antes de modificar o ejecutar acciones riesgosas."

    if [[ "$lower" =~ (100%|readiness|release.?ready|release.?readiness|falta|pendiente|brecha|brechas) ]]; then
