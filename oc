#!/usr/bin/env bash

set -e

OC_CONFIG="${HOME}/.config/opencode"
OC_BIN="${HOME}/.local/bin"
OC_MEMORY="${OC_CONFIG}/memory"
OC_PROFILES="${OC_CONFIG}/profiles"
CURRENT_PROFILE="${OC_CONFIG}/.current_profile"

OC_BUDGET_FILE="${OC_CONFIG}/.budget"
OC_SESSION_FILE="${OC_CONFIG}/.session"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[OK]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

track_turn() {
    local session_id=$(date +%Y%m%d-%H%M%S)
    local turns=1
    if [ -f "${OC_SESSION_FILE}" ]; then
        turns=$(($(cat "${OC_SESSION_FILE}") + 1))
    fi
    echo "$turns" > "${OC_SESSION_FILE}"

    local budget_threshold=80
    local warn_level=$(($turns * 100 / $budget_threshold))

    if [ $turns -gt 20 ]; then
        warn "Session turns: $turns (consider context compaction)"
    fi
}

check_budget() {
    local turns=0
    [ -f "${OC_SESSION_FILE}" ] && turns=$(cat "${OC_SESSION_FILE}")

    if [ $turns -gt 50 ]; then
        warn "High session turns ($turns). Context may need compaction."
        return 1
    fi
    return 0
}

check_deps() {
    local missing=()
    for cmd in fzf opencode; do
        command -v $cmd >/dev/null 2>&1 || missing+=($cmd)
    done
    if [ ${#missing[@]} -gt 0 ]; then
        error "Dependencies missing: ${missing[*]}. Install with: dnf install fzf"
    fi
}

show_budget() {
    local turns=0
    [ -f "${OC_SESSION_FILE}" ] && turns=$(cat "${OC_SESSION_FILE}")
    echo "Session turns: $turns"
    [ $turns -gt 20 ] && echo "Consider running: oc --compact"
}

generate_obs_id() {
    date +%Y%m%d-%H%M%S-%N | head -c 12
}

create_observation() {
    local type="${1:-note}"
    local content="$2"
    local project="${3:-global}"
    local obs_id=$(generate_obs_id)

    if [ -z "$content" ]; then
        echo "Error: content is required"
        return 1
    fi

    local obs_dir="${OC_MEMORY}/projects/${project}"
    mkdir -p "$obs_dir"

    local obs_file="${obs_dir}/${obs_id}.md"

    cat > "$obs_file" << EOF
---
id: obs_${obs_id}
date: $(date +%Y-%m-%d\ %H:%M:%S)
project: ${project}
type: ${type}
summary: ${content:0:100}
tokens_est: 200
---

${content}

$(echo "<private>"; echo "Contenido sensible aqui"; echo "</private>")
EOF

    echo "$obs_id" > "${OC_MEMORY}/.last_obs_id"
    success "Observation created: obs_${obs_id}"

    grep -q "^<!-- INDEX_START -->" "${OC_MEMORY}/INDEX.md" && {
        echo "obs_${obs_id} | $(date +%Y-%m-%d) | ${project} | ${type} | ${content:0:80}" >> "${OC_MEMORY}/INDEX.md"
    }
}

search_memory() {
    local query="${1:-}"
    local project="${2:-}"
    local type="${3:-}"

    if [ -z "$query" ]; then
        echo "Usage: oc --memory <query> [-p project] [-t type]"
        return 1
    fi

    if [ ! -f "${OC_MEMORY}/INDEX.md" ]; then
        warn "No memory index found. Use oc --remember to add observations."
        return 1
    fi

    local results=$(grep -i "$query" "${OC_MEMORY}/INDEX.md" 2>/dev/null | head -20)

    if [ -z "$results" ]; then
        echo "No results found for: $query"
        return 1
    fi

    echo -e "${BLUE}=== Memory Search Results ===${NC}"
    echo "$results" | while IFS= read -r line; do
        echo "$line"
    done
    echo ""
    echo "Use --timeline <obs_id> for context or --get <id1,id2> for full details."
}

get_observations() {
    local ids="${1:-}"

    if [ -z "$ids" ]; then
        echo "Usage: oc --get <obs_id1,obs_id2,...>"
        return 1
    fi

    IFS=',' read -ra OBS_IDS <<< "$ids"

    for obs_id in "${OBS_IDS[@]}"; do
        obs_id=$(echo "$obs_id" | tr -d ' ')
        local obs_file=$(find "${OC_MEMORY}" -name "${obs_id}.md" 2>/dev/null | head -1)

        if [ -z "$obs_file" ]; then
            warn "Observation not found: $obs_id"
            continue
        fi

        echo -e "${BLUE}=== obs_${obs_id} ===${NC}"
        cat "$obs_file"
        echo ""
    done
}

get_timeline() {
    local obs_id="${1:-}"

    if [ -z "$obs_id" ]; then
        echo "Usage: oc --timeline <obs_id>"
        return 1
    fi

    local obs_file=$(find "${OC_MEMORY}" -name "${obs_id}.md" 2>/dev/null | head -1)

    if [ -z "$obs_file" ]; then
        warn "Observation not found: $obs_id"
        return 1
    fi

    local obs_dir=$(dirname "$obs_file")
    local project=$(grep "^project:" "$obs_file" | cut -d':' -f2 | tr -d ' ')

    echo -e "${BLUE}=== Timeline around $obs_id ===${NC}"
    ls -t "$obs_dir"/*.md 2>/dev/null | head -5 | while read -r f; do
        local fname=$(basename "$f" .md)
        local summary=$(grep "^summary:" "$f" 2>/dev/null | cut -d':' -f2 | tr -d ' ')
        local date=$(grep "^date:" "$f" 2>/dev/null | cut -d':' -f2 | tr -d ' ')
        echo "$fname | $date | ${summary:0:80}"
    done
}

capture_session() {
    info "Session started: $(date)"
    info "Project: ${PWD}"
    echo "---" >> "${OC_MEMORY}/sessions.log"
    echo "Session: $(date)" >> "${OC_MEMORY}/sessions.log"
    echo "Directory: ${PWD}" >> "${OC_MEMORY}/sessions.log"
}

check_deps
track_turn

