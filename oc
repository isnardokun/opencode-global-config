        run_init "${2:-.}"
        ;;
    -t|--type)
        shift
        _type="$1"
        shift
        search_memory "$*" "" "$_type"
        ;;
    --timeline)
        get_timeline "$2"
        ;;
    --get)
        get_observations "$2"
        ;;
    --list-templates)
        list_observation_templates
        ;;
    --capture)
        capture_session
        ;;
    --save-all)
        save_all
        ;;
    --remember)
        shift
        _type="note"
        _project="global"
        _use_template=0
        while [ $# -gt 0 ]; do
            case "$1" in
                -t|--type)
                    shift
                    _type="${1:-note}"
                    shift || true
                    ;;
                -p|--project)
                    shift
                    _project="${1:-global}"
                    shift || true
                    ;;
                --template)
                    _use_template=1
                    shift || true
                    ;;
                *)
                    break
                    ;;
            esac
        done

        if [ "$_use_template" -eq 1 ] || [ -z "$*" ]; then
            list_observation_templates
            echo ""
            echo "To fill a template, use:"
            echo "  oc --remember -t ${_type} -p ${_project} '<your content>'"
            echo ""
            if [ "$_use_template" -eq 1 ]; then
                echo "--- Template Preview for '${_type}' ---"
                render_observation_template "$_type" "$_project" ""
            fi
        else
            create_observation "$_type" "$*" "$_project"
        fi
        ;;
    --memory)
        shift
        if [ "${1:-}" == "--timeline" ]; then
            get_timeline "$2"
        elif [ "${1:-}" == "--get" ]; then
            get_observations "$2"
        elif printf '%s\n' "$@" | grep -Eq '^-p$|^--project$|^-t$|^--type$'; then
            _type=""
            _project=""
            _query=()
            while [ $# -gt 0 ]; do
                case "$1" in
                    -t|--type)
                        shift
                        _type="${1:-}"
                        ;;
                    -p|--project)
                        shift
                        _project="${1:-}"
                        ;;
                    *)
                        _query+=("$1")
                        ;;
                esac
                shift || true
            done
            search_memory "${_query[*]}" "$_project" "$_type"
        else
            search_memory "$*"
        fi
        ;;
    -p|--profile)
        switch_profile "$2"
        ;;
    -l|--list-profiles)
        list_profiles
        ;;
    -h|--help)
        show_help
        ;;
    --compact)
        info "Generating session summary..."
