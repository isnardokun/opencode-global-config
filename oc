ask_command() {
    local dry_run=0 explain=0 clarify=0
    local args=()

    shift
    while [ $# -gt 0 ]; do
        case "$1" in
            --dry-run) dry_run=1 ;;
            --explain) explain=1 ;;
            --clarify) clarify=1 ;;
            -h|--help) ask_usage; return 0 ;;
            *) args+=("$1") ;;
        esac
        shift || true
    done

    if [ "${#args[@]}" -eq 0 ]; then
        ask_usage
        return 1
    fi

    [ "$dry_run" -eq 1 ] && clarify=0

    local task="${args[*]}"
    if [ "$clarify" -eq 1 ]; then
        local answer
        read -rp "Objetivo concreto: " answer
        [ -n "$answer" ] && task="$task | Objetivo: $answer"
        read -rp "Ruta/archivo/proyecto relevante (opcional): " answer
        [ -n "$answer" ] && task="$task | Contexto: $answer"
        read -rp "Restricciones o criterios de éxito (opcional): " answer
        [ -n "$answer" ] && task="$task | Criterios: $answer"
    fi

    local route_output intent route prompt
    route_output=$(ask_route "$task")
    intent=$(printf '%s\n' "$route_output" | sed -n '1p')
    route=$(printf '%s\n' "$route_output" | sed -n '2p')
    prompt=$(printf '%s\n' "$route_output" | sed '1,2d')

    if [ "$dry_run" -eq 1 ] || [ "$explain" -eq 1 ]; then
        echo "Intent: $intent"
        echo "Route: $route"
        echo "Prompt:"
        printf '%s\n' "$prompt"
    fi

    [ "$dry_run" -eq 1 ] && return 0
    _oc_run -p "$prompt"
}

