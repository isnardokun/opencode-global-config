#!/usr/bin/env bash

OC_CONFIG="${HOME}/.config/opencode"
OC_BIN="${HOME}/.local/bin"
OC_MEMORY="${OC_CONFIG}/memory"
OC_PROFILES="${OC_CONFIG}/profiles"
CURRENT_PROFILE="${OC_CONFIG}/.current_profile"

OC_BUDGET_FILE="${OC_CONFIG}/.budget"
OC_SESSION_FILE="${OC_CONFIG}/.session"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[OK]${NC} $1"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $1"; }
error()   { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

track_turn() {
    local turns=1
    mkdir -p "${OC_CONFIG}"
    if [ -f "${OC_SESSION_FILE}" ]; then
        local current
        current=$(cat "${OC_SESSION_FILE}" 2>/dev/null || printf '0')
        if [[ "$current" =~ ^[0-9]+$ ]]; then
            turns=$((current + 1))
        fi
    fi
    echo "$turns" > "${OC_SESSION_FILE}"
    if [ "$turns" -gt 20 ]; then
        warn "Session turns: $turns (consider context compaction)"
    fi

    # Self-Improvement: track outcomes and reflect periodically
    if [ "${turns}" -gt 0 ] && [ $((turns % 5)) -eq 0 ]; then
        track_outcome "interaction" "active" "$(detect_project 2>/dev/null || echo 'unknown')" "Session turn ${turns}"
    fi
    if [ "${turns}" -gt 0 ] && [ $((turns % 15)) -eq 0 ]; then
        auto_reflect "interaction" "$(pwd 2>/dev/null || echo '.')" 0
    fi
}

check_budget() {
    local turns=0
    [ -f "${OC_SESSION_FILE}" ] && turns=$(cat "${OC_SESSION_FILE}")
    if [ "$turns" -gt 50 ]; then
        warn "High session turns ($turns). Context may need compaction."
    fi
}

