auto_reflect() {
    local workflow="$1"
    local target="$2"
    local turns=0
    [ -f "${OC_SESSION_FILE}" ] && turns=$(cat "${OC_SESSION_FILE}" 2>/dev/null || echo 0)

    local project=$(basename "$target" 2>/dev/null || echo "unknown")

    cat << REFLECTION

--- Post-Workflow Reflection ---
Workflow: $workflow
Target: $target
Session turns: ${turns}
Was this successful? [y/n/skip]:
REFLECTION

    read -rp "Reflection (what went well/what didn't): " reflection

    if [[ "$reflection" == "skip" ]] || [[ -z "$reflection" ]]; then
        return 0
    fi

    local type="note"
    if [[ "$reflection" == "n" ]] || [[ "$reflection" == "N" ]]; then
        type="bugfix"
    fi

    create_observation "$type" "${workflow} outcome for ${project}: ${reflection}" "$project"
}

analyze_patterns() {
    local outcome_dir="${OC_MEMORY}/outcomes"
    [ ! -d "$outcome_dir" ] && return 0

    local failure_count=0
    local recent_failures=""

    for f in "${outcome_dir}"/*.json; do
        [ -f "$f" ] || continue
        local content=$(cat "$f" 2>/dev/null)
        if echo "$content" | grep -q '"failure"'; then
            failure_count=$((failure_count + 1))
            recent_failures="${recent_failures}  - $(echo "$content" | python3 -c 'import json,sys; d=json.load(sys.stdin); print(d.get("workflow","?") + ": " + d.get("details","?"))' 2>/dev/null)\n"
        fi
    done

    if [ "$failure_count" -ge 3 ]; then
        echo ""
        warn "Pattern detected: ${failure_count} workflow failures in recent history"
        echo "Recent failures:"
        printf '%b' "$recent_failures"
        echo ""
        info "Suggestion: Consider creating a rule in AGENTS.md or adjusting workflow parameters"
        echo "  oc --list-templates   # to document lessons learned"
        echo "  oc --remember -t decision 'workflow pattern: ...'"
    fi
}

