confirm() {
    local prompt="${1:-Continuar?}"
    local response
    read -rp "$prompt [y/n]: " response
    [[ "$response" == "y" ]] || [[ "$response" == "Y" ]]
}

run_workflow() {
    local workflow="${1:-}"
    local target="${2:-.}"
    local interactive="${3:-false}"
    local feature_desc="${4:-nueva funcionalidad}"

    case "$workflow" in
        bug-hunt)
            echo -e "${BLUE}=== Bug Hunt Pipeline (single-pass) ===${NC}"
            if [ "$interactive" == "true" ]; then confirm "¿Iniciar?" || return 0; fi
            _oc_run -p "Ejecuta el siguiente workflow completo para: $target

FASE 1 - @architect con project-map:
Analiza el proyecto en: $target
Identifica archivos críticos y posibles áreas con bugs.
Reporta: stack detectado, estructura, riesgos.

FASE 2 - @security-auditor:
Revisa el código buscando: errores lógicos, variables indefinidas, imports rotos, memory leaks, edge cases no manejados.
No modifiques nada. Lista todos los problemas encontrados con severidad.

FASE 3 - @planner:
Basado en los problemas encontrados, crea plan de corrección con fases verificables.
Ordena por prioridad: crítico → alto → bajo.

FASE 4 - @builder con safe-implementation y test-first:
Implementa las correcciones planificadas en: $target
Máximo 3 archivos por iteración. Agrega tests para cada fix.

FASE 5 - @reviewer con precommit-review:
Verifica que los fixes funcionan correctamente.
Confirma que no se introdujeron nuevos errores.
Reporta resultado final.

Ejecuta todas las fases en secuencia. Reporta resultados de cada fase antes de continuar a la siguiente."
            echo -e "${GREEN}=== Bug Hunt Completado ===${NC}"
            create_observation "bugfix" "Bug hunt completado en $target" "$(basename "$target")"
            ;;

        new-project)
            echo -e "${BLUE}=== New Project Setup Pipeline (single-pass) ===${NC}"
            if [ "$interactive" == "true" ]; then confirm "¿Iniciar?" || return 0; fi
            _oc_run -p "Ejecuta el siguiente workflow completo para nuevo proyecto: $target

FASE 1 - @architect:
Analiza el contexto: $target
Identifica stack recomendado, dependencias y arquitectura inicial.

FASE 2 - @planner:
Planifica la estructura del proyecto. Incluye:
- Estructura de directorios
- Archivos de configuración necesarios
- Dependencias
- Tests iniciales a escribir

FASE 3 - @builder con safe-implementation:
Crea la estructura básica del proyecto: $target
Genera los archivos base según el plan.

FASE 4 - @docs-writer:
Genera documentación inicial:
- README.md con instalación y uso
- ARCHITECTURE.md con estructura
- CONTRIBUTING.md si es proyecto colaborativo

Ejecuta todas las fases en secuencia."
            echo -e "${GREEN}=== New Project Completado ===${NC}"
            create_observation "feature" "Proyecto inicializado: $target" "$(basename "$target")"
            ;;

        debug)
            echo -e "${BLUE}=== Production Debug Pipeline (single-pass) ===${NC}"
            if [ "$interactive" == "true" ]; then confirm "¿Iniciar?" || return 0; fi
            _oc_run -p "Ejecuta el siguiente workflow de debug para: $target

FASE 1 - @oncall:
Diagnostica el problema en: $target
Clasifica por urgencia (P1/P2/P3) e identifica causa raíz.
Lista mitigaciones inmediatas disponibles.

FASE 2 - @builder con safe-implementation y test-first:
Implementa la corrección para: $target
Escribe test que reproduce el bug primero, luego hazlo pasar.

FASE 3 - @security-auditor:
Verifica que la corrección no introduce vulnerabilidades.
Confirma que el fix es correcto y completo.

Ejecuta todas las fases en secuencia."
            echo -e "${GREEN}=== Debug Completado ===${NC}"
            create_observation "bugfix" "Debug completado en $target" "$(basename "$target")"
            ;;

        document)
            echo -e "${BLUE}=== Codebase Documentation Pipeline (single-pass) ===${NC}"
            if [ "$interactive" == "true" ]; then confirm "¿Iniciar?" || return 0; fi
            _oc_run -p "Ejecuta el siguiente workflow de documentación para: $target

FASE 1 - @architect con project-map:
Análisis completo de: $target
Documenta: stack tecnológico, estructura de archivos, entry points, APIs, dependencias, configuraciones.

FASE 2 - @docs-writer:
Genera documentación completa para: $target
Crea o actualiza:
- README.md (propósito, instalación, uso, ejemplos)
- ARCHITECTURE.md (diagrama, componentes, flujo de datos)
- API.md (endpoints, formatos, ejemplos) si aplica
- DEPLOY.md (instrucciones de deployment) si aplica

FASE 3 - @reviewer:
Verifica que la documentación:
- Refleja el código real (accurate)
- Cubre casos importantes (completa)
- No tiene información obsoleta (actualizada)
Reporta solo problemas encontrados.

Ejecuta todas las fases en secuencia."
            echo -e "${GREEN}=== Documentation Completada ===${NC}"
            create_observation "feature" "Documentación generada para $target" "$(basename "$target")"
            ;;

        feature)
            echo -e "${BLUE}=== Feature Development Pipeline (single-pass) ===${NC}"
            echo "Feature: $feature_desc"
            echo "Target: $target"
            if [ "$interactive" == "true" ]; then confirm "¿Iniciar?" || return 0; fi
            _oc_run -p "Ejecuta el siguiente workflow para implementar: $feature_desc en: $target

FASE 1 - @architect:
Analiza: $target para implementar: $feature_desc
Identifica:
- Archivos a modificar
- Puntos de extensión existentes
- Posibles conflictos con código existente
- Tradeoffs del approach

FASE 2 - @planner:
Planifica la implementación de: $feature_desc en: $target
Divide en pasos verificables con criterios de éxito claros.

FASE 3 - @builder con safe-implementation y test-first:
Implementa: $feature_desc
Escribe tests primero, luego implementación.
Máximo 3 archivos por iteración.

FASE 4 - @reviewer con precommit-review:
Revisa la implementación de $feature_desc
Verifica: correctitud, tests, no regresiones, código limpio.

Ejecuta todas las fases en secuencia."
            echo -e "${GREEN}=== Feature Completada ===${NC}"
            create_observation "feature" "Feature implementada: $feature_desc" "$(basename "$target")"
            ;;

        "")
            echo "Usage: oc --workflow <name> [target|feature_desc] [path] [--interactive]"
            echo ""
            echo "Available workflows:"
            echo "  bug-hunt      - Find and fix bugs (5 phases)"
            echo "  new-project   - Setup new project (4 phases)"
            echo "  debug         - Debug production issue (3 phases)"
            echo "  document      - Generate documentation (3 phases)"
            echo "  feature       - Develop a feature (4 phases)"
            echo ""
            echo "Examples:"
            echo "  oc --workflow bug-hunt ~/myproject"
            echo "  oc --workflow feature \"add OAuth2\" ~/myapi"
            ;;
        *)
            echo "Unknown workflow: $workflow"
            echo "Available: bug-hunt, new-project, debug, document, feature"
            ;;
    esac
}

list_workflows() {
    echo "Available workflows:"
    echo "  bug-hunt      - Find and fix bugs (5 phases, single-pass)"
    echo "  new-project   - Setup new project (4 phases, single-pass)"
    echo "  debug         - Debug production issue (3 phases, single-pass)"
    echo "  document      - Generate documentation (3 phases, single-pass)"
    echo "  feature       - Develop a feature (4 phases, single-pass)"
}

if [ $# -eq 0 ]; then
    opencode
    exit 0
fi

case "$1" in
    -w|--wizard)
        run_wizard
        ;;
    -i|--interactive)
        run_interactive
        ;;
    --init)
        run_init "${2:-.}"
        ;;
    -t|--type)
        shift
        _type="$1"
        shift
        search_memory "$*" "" "$_type"
        ;;
    --timeline)
        get_timeline "$2"
        ;;
    --get)
        get_observations "$2"
        ;;
    --capture)
        capture_session
        ;;
    --remember)
        shift
        _type="note"
        if [ "${1:-}" == "-t" ]; then
            shift
            _type="$1"
            shift
        fi
        create_observation "$_type" "$*"
        ;;
    --memory)
        shift
        if [ "${1:-}" == "--timeline" ]; then
            get_timeline "$2"
        elif [ "${1:-}" == "--get" ]; then
            get_observations "$2"
        elif [ "${1:-}" == "-t" ]; then
            shift
            _type="$1"
            shift
            search_memory "$*" "" "$_type"
        else
            search_memory "$1" "${2:-}" "${3:-}"
        fi
        ;;
    -p|--profile)
        switch_profile "$2"
        ;;
    -l|--list-profiles)
        list_profiles
        ;;
    -h|--help)
        show_help
        ;;
    --compact)
        info "Generating session summary..."
        _oc_run -p "Summarize this entire session in a structured markdown document with these sections:
## Goal
What was the main task or objective?

## Findings
Key things discovered or analyzed (file paths, functions, issues found).

## Changes Made
Every file modified or created, with a one-line description of what changed and why.

## Decisions
Technical decisions made and the reasoning behind each.

## Current State
What is the state of the project/task right now?

## Remaining Work
What has not been done yet, if anything?

Keep all technical details. Eliminate conversational back-and-forth. Be concrete with file paths and function names.
Output as plain markdown. This will be saved to resume the session later."
        echo "0" > "${OC_SESSION_FILE}"
        success "Context compacted. Turn counter reset."
        info "Save the summary above to memory with: oc --remember -p <project> '<summary>'"
        ;;
    --budget)
        show_budget
        ;;
    --doctor)
        _doc_ok=1
        echo -e "${BLUE}OpenCode Global Config — Doctor${NC}"
        echo "================================"
        echo ""

        # Check opencode
        if command -v opencode >/dev/null 2>&1; then
            echo -e "${GREEN}✅${NC} opencode: $(command -v opencode)"
        else
            echo -e "${RED}❌${NC} opencode not found — install from https://opencode.ai"
            _doc_ok=0
        fi

        # Check oc
        if command -v oc >/dev/null 2>&1; then
            echo -e "${GREEN}✅${NC} oc: $(command -v oc)"
        else
            echo -e "${YELLOW}⚠️${NC}  oc not in PATH — run: export PATH=\"\$HOME/.local/bin:\$PATH\""
            _doc_ok=0
        fi

        # Check config files
        _idir="${OC_CONFIG}"
        for _f in opencode.json AGENTS.md CLAUDE.md; do
            if [ -f "${_idir}/${_f}" ]; then
                echo -e "${GREEN}✅${NC} ${_f}"
            else
                echo -e "${RED}❌${NC} Missing: ${_idir}/${_f}"
                _doc_ok=0
            fi
        done

        # Check dirs
        for _d in agents skills plugins commands memory profiles; do
            if [ -d "${_idir}/${_d}" ]; then
                echo -e "${GREEN}✅${NC} ${_d}/"
            else
                echo -e "${RED}❌${NC} Missing directory: ${_idir}/${_d}/"
                _doc_ok=0
            fi
        done

        # Check opencode.json valid JSON
        if command -v jq >/dev/null 2>&1; then
            if jq empty "${_idir}/opencode.json" >/dev/null 2>&1; then
                echo -e "${GREEN}✅${NC} opencode.json valid JSON"
            else
                echo -e "${RED}❌${NC} opencode.json invalid JSON"
                _doc_ok=0
            fi
        else
            echo -e "${YELLOW}⚠️${NC}  jq not installed — skipping JSON validation"
        fi

        # Check fzf
        if command -v fzf >/dev/null 2>&1; then
            echo -e "${GREEN}✅${NC} fzf: $(command -v fzf)"
        else
            echo -e "${YELLOW}⚠️${NC}  fzf not installed — oc --interactive unavailable"
        fi

        # Check active profile
        _active=$(get_active_profile)
        if [ -n "$_active" ]; then
            echo -e "${GREEN}✅${NC} Active profile: ${_active}"
        else
            echo -e "${BLUE}ℹ️${NC}  No active profile (using OpenCode defaults)"
        fi

        # Check safety-guard.js audit log
        _logfile="${_idir}/logs/safety-guard.jsonl"
        if [ -f "$_logfile" ]; then
            _lines=$(wc -l < "$_logfile" 2>/dev/null || echo 0)
            echo -e "${GREEN}✅${NC} Audit log: ${_lines} entries (${_logfile})"
        else
            echo -e "${BLUE}ℹ️${NC}  Audit log not yet created (safety-guard.jsonl)"
        fi

        echo ""
        if [ "$_doc_ok" -eq 1 ]; then
            success "All checks passed."
        else
            warn "Some checks failed. Run installer to fix:"
            echo "  curl -fsSL https://raw.githubusercontent.com/isnardokun/opencode-global-config/main/install.sh | bash"
        fi
        ;;
    --workflow)
        shift
        _wf_name="${1:-}"
        shift
        _wf_interactive="false"
        _wf_feature=""
        _wf_target="."
        # feature workflow takes description as first arg, path as second
        if [ "$_wf_name" = "feature" ]; then
            _wf_feature="${1:-nueva funcionalidad}"
            shift
            _wf_target="${1:-.}"
            shift
        else
            _wf_target="${1:-.}"
            shift
        fi
        [ "${1:-}" = "--interactive" ] && _wf_interactive="true"
        run_workflow "$_wf_name" "$_wf_target" "$_wf_interactive" "$_wf_feature"
        ;;
    --list-workflows)
        list_workflows
        ;;
    analyze)
        quick_analyze "${2:-.}"
        ;;
    plan)
        quick_plan "$2"
        ;;
    build)
        shift
        quick_build "$*"
        ;;
    review)
        quick_review
        ;;
    secure)
        quick_secure
        ;;
    docs)
        quick_docs
        ;;
    devops)
        shift
        quick_devops "$*"
        ;;
    oncall)
        quick_oncall
        ;;
    *)
        _oc_run -p "$*"
        ;;
esac
