detect_stack() {
    local dir="${1:-.}"
    local stacks=()
    [ -f "${dir}/package.json" ]                                   && stacks+=("Node.js")
    { [ -f "${dir}/pyproject.toml" ] || [ -f "${dir}/requirements.txt" ]; } && stacks+=("Python")
    [ -f "${dir}/Cargo.toml" ]                                     && stacks+=("Rust")
    [ -f "${dir}/go.mod" ]                                         && stacks+=("Go")
    { [ -f "${dir}/pom.xml" ] || [ -f "${dir}/build.gradle" ]; }        && stacks+=("Java")
    { [ -f "${dir}/docker-compose.yml" ] || [ -f "${dir}/Dockerfile" ]; } && stacks+=("Docker")
    { [ -f "${dir}/terraform.tf" ] || [ -d "${dir}/.terraform" ]; }     && stacks+=("Terraform")
    printf '%s\n' "${stacks[@]}"
}

detect_test_commands() {
    local dir="${1:-.}"
    [ -f "${dir}/package.json" ] && grep -q '"test"' "${dir}/package.json" && echo "npm test"
    { [ -f "${dir}/pyproject.toml" ] || [ -f "${dir}/requirements.txt" ] || [ -f "${dir}/setup.py" ]; } && echo "pytest"
    [ -f "${dir}/Cargo.toml" ]                                              && echo "cargo test"
    [ -f "${dir}/go.mod" ]                                                  && echo "go test ./..."
    [ -f "${dir}/Makefile" ] && grep -q "^test:" "${dir}/Makefile"          && echo "make test"
}

# Get skill IDs for a given stack from registry
get_skills_for_stack() {
    local stack="$1"
    local registry_file="${OC_CONFIG}/skills-registry.json"

    if [ ! -f "$registry_file" ]; then
        # Fallback to local skills if registry not installed
        case "$stack" in
            "Node.js") echo "project-map safe-implementation test-first" ;;
            "Python") echo "project-map safe-implementation test-first" ;;
            "Go") echo "project-map safe-implementation test-first" ;;
            "Rust") echo "project-map safe-implementation test-first" ;;
            "Docker") echo "project-map safe-implementation precommit-review" ;;
            *) echo "project-map" ;;
        esac
        return
    fi

    # Parse registry with jq
    if command -v jq >/dev/null 2>&1; then
        jq -r ".skills.${stack}[]?.id // empty" "$registry_file" 2>/dev/null | grep -v "^$"
    else
        # Fallback without jq
        case "$stack" in
            "Node.js") echo "project-map safe-implementation test-first precommit-review memory-retrieval" ;;
            "Python") echo "project-map safe-implementation test-first precommit-review memory-retrieval" ;;
            "Go") echo "project-map safe-implementation test-first precommit-review" ;;
            "Rust") echo "project-map safe-implementation test-first" ;;
            "Docker"|"Terraform") echo "project-map safe-implementation precommit-review" ;;
            *) echo "project-map safe-implementation" ;;
        esac
    fi
}

# Install skills for detected stacks
install_skills_for_stacks() {
    local target_dir="${1:-.}"
    local detected_stacks
    detected_stacks=$(detect_stack "$target_dir")

    if [ -z "$detected_stacks" ]; then
        info "No se detectó stack definido — instalando skills universales"
        detected_stacks="universal"
    fi

    local installed_count=0
    local skipped_count=0

    while IFS= read -r stack; do
        [ -z "$stack" ] && continue

        local skill_ids
        skill_ids=$(get_skills_for_stack "$stack")

        for skill_id in $skill_ids; do
            # Check if skill already exists locally
            if [ -d "${OC_CONFIG}/skills/${skill_id}" ]; then
                skipped_count=$((skipped_count + 1))
                continue
            fi

            # Install from registry if source is autoskills
            local registry_file="${OC_CONFIG}/skills-registry.json"
            if [ -f "$registry_file" ] && command -v jq >/dev/null 2>&1; then
                local source
                source=$(jq -r ".skills.${stack}[] | select(.id==\"$skill_id\") | .source // empty" "$registry_file" 2>/dev/null)
                if [ "$source" = "autoskills" ]; then
                    local skill_url
                    skill_url=$(jq -r ".skills.${stack}[] | select(.id==\"$skill_id\") | .repo + \"/raw/main/\" + .path + \"/SKILL.md\" // empty" "$registry_file" 2>/dev/null)
                    if [ -n "$skill_url" ] && [ "$skill_url" != "null" ]; then
                        mkdir -p "${OC_CONFIG}/skills/${skill_id}"
                        if curl -sSL "$skill_url" -o "${OC_CONFIG}/skills/${skill_id}/SKILL.md" 2>/dev/null; then
                            info "Installed skill: $skill_id ($stack)"
                            installed_count=$((installed_count + 1))
                        fi
                    fi
                fi
            fi
        done
    done <<< "$detected_stacks"

    # Always ensure universal skills are present
    # Try to find skills in: OC_CONFIG (global install), same dir as oc, or current dir
    for universal_skill in project-map safe-implementation test-first precommit-review memory-retrieval docs-writer; do
        if [ ! -d "${OC_CONFIG}/skills/${universal_skill}" ]; then
            local source_dir=""
            # Check global config first
            [ -d "${OC_CONFIG}/skills/${universal_skill}" ] && source_dir="${OC_CONFIG}/skills"
            # Check relative to oc binary location
            if [ -z "$source_dir" ] && [ -f "${BASH_SOURCE[0]}" ]; then
                local oc_dir
                oc_dir=$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${0}")")
                [ -d "${oc_dir}/../skills/${universal_skill}" ] && source_dir="${oc_dir}/../skills"
            fi
            # Check current working directory (repo)
            if [ -z "$source_dir" ] && [ -d "$(pwd)/skills/${universal_skill}" ]; then
                source_dir="$(pwd)/skills"
            fi
            if [ -n "$source_dir" ] && [ -d "${source_dir}/${universal_skill}" ]; then
                cp -r "${source_dir}/${universal_skill}" "${OC_CONFIG}/skills/${universal_skill}" 2>/dev/null && installed_count=$((installed_count + 1))
            fi
        fi
    done

    if [ "$installed_count" -gt 0 ]; then
        success "Skills instalados: $installed_count"
    fi
    if [ "$skipped_count" -gt 0 ]; then
        info "Skills ya existentes (omitidos): $skipped_count"
    fi
}

# List available skills for detected stack
list_skills_for_stack() {
    local target_dir="${1:-.}"

    if [ ! -f "${OC_CONFIG}/skills-registry.json" ]; then
        echo "Registry no instalado. Ejecuta: oc --install-skills-registry"
        return
    fi

    local detected_stacks
    detected_stacks=$(detect_stack "$target_dir")

    if [ -z "$detected_stacks" ]; then
        detected_stacks="universal"
    fi

    echo ""
    echo "=== Skills disponibles para tu stack ==="
    echo ""

    while IFS= read -r stack; do
        [ -z "$stack" ] && continue
        echo "[$stack]"

        local skill_ids
        skill_ids=$(get_skills_for_stack "$stack")

        for skill_id in $skill_ids; do
            local installed=""
            [ -d "${OC_CONFIG}/skills/${skill_id}" ] && installed=" ✅"

            local desc=$(jq -r ".skills.${stack}[] | select(.id==\"$skill_id\") | .description // \"\" " "${OC_CONFIG}/skills-registry.json" 2>/dev/null)
            echo "  • $skill_id$installed — $desc"
        done
        echo ""
    done <<< "$detected_stacks"
}

run_init() {
    local target_dir="${1:-.}"
    local opencode_dir="${target_dir}/.opencode"

    if [ -d "${opencode_dir}" ]; then
        warn "Ya existe ${opencode_dir}/"
        read -rp "Sobrescribir? [y/n]: " confirm
        [[ "$confirm" != "y" ]] && exit 0
        rm -rf "${opencode_dir}"
    fi

    info "Creando estructura de proyecto..."
    mkdir -p "${opencode_dir}"/{agents,skills,mcp,hooks}

    cat > "${opencode_dir}/opencode.json" << 'EOF'
{
  "$schema": "https://opencode.ai/config.json",
  "extends": "~/.config/opencode/opencode.json",
  "project": {
    "name": "",
    "stack": [],
    "entrypoints": []
  },
  "agents": {
    "project": "./agents"
  }
}
EOF

    # Detect stack and test commands
    local detected_stacks
    detected_stacks=$(detect_stack "$target_dir")
    local detected_tests
    detected_tests=$(detect_test_commands "$target_dir")

    if [ -n "$detected_stacks" ]; then
        info "Stack detectado: $(echo "$detected_stacks" | tr '\n' ' ')"
    fi

    # Generate CLAUDE.md with detected context
    {
        echo "# Project Context"
        echo ""
        echo "## Description"
        echo "Describe the project here."
        echo ""
        if [ -n "$detected_stacks" ]; then
            echo "## Detected Stack"
            while IFS= read -r stack; do
                echo "- $stack"
            done <<< "$detected_stacks"
            echo ""
        else
            echo "## Stack"
            echo "- ..."
            echo ""
        fi
        echo "## Commands"
        echo '```bash'
        if [ -n "$detected_tests" ]; then
            while IFS= read -r cmd; do
                echo "$cmd"
            done <<< "$detected_tests"
        else
            echo "# add test, lint, build commands here"
        fi
        echo '```'
        echo ""
        echo "## Notes"
        echo "- Project-specific configuration"
        echo "- Team conventions"
        echo "- Do not modify .env files"
    } > "${opencode_dir}/CLAUDE.md"

    if [ -d "${target_dir}/.git" ]; then
        mkdir -p "${target_dir}/.git/hooks"
        cat > "${target_dir}/.git/hooks/pre-commit" << 'HOOK'
#!/bin/bash

echo ""
echo "🔍 OpenCode Pre-Commit Review"
echo "=============================="

tmp_output=$(mktemp)
trap 'rm -f "$tmp_output"' EXIT

hook_timeout_seconds="${OC_HOOK_TIMEOUT_SECONDS:-60}"
if command -v timeout >/dev/null 2>&1; then
    timeout_cmd="timeout"
elif command -v gtimeout >/dev/null 2>&1; then
    timeout_cmd="gtimeout"
else
    echo ""
    echo "❌ Pre-commit rechazado. No se encontró timeout/gtimeout para limitar la revisión."
    exit 1
fi

diff_context=$(git diff --cached --name-status && printf '\n' && git diff --cached --stat)
if [ -z "$diff_context" ]; then
    diff_context="No hay diff staged disponible. Revisa el estado Git si aplica."
fi

if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --verbose; then
        echo ""
        echo "❌ Pre-commit rechazado. gitleaks detectó posibles secretos."
        exit 1
    fi
else
    echo "⚠️  gitleaks no está instalado; se omite escaneo local de secretos."
fi

if [ "${OC_HOOK_LLM:-0}" != "1" ]; then
    echo "ℹ️  Revisión LLM omitida (actívala con OC_HOOK_LLM=1)."
    echo "✅ Pre-commit aprobado"
    exit 0
fi

prompt="
Revisión pre-commit metadata-only.

No uses agentes, herramientas, bash, grep, git ni lecturas de archivos.
Usa únicamente la metadata incluida abajo. No intentes inspeccionar el repositorio.

Revisa los archivos modificados en este commit usando solo metadata.

Metadata staged (name-status + stat; no patch body):
$diff_context

Reglas:
- No modifiques archivos.
- Reporta solo hallazgos.
- Si hay errores críticos, el commit será rechazado.
- La última línea no vacía de tu respuesta debe ser exactamente HOOK_REVIEW_RESULT=pass o HOOK_REVIEW_RESULT=fail.

Resumen esperado:
1. Archivos modificados
2. Hallazgos críticos (bloqueantes)
3. Hallazgos medios
4. Pruebas ejecutadas
5. Recomendación: aprobar/corregir

Termina con una línea final exacta, sin texto después:
HOOK_REVIEW_RESULT=pass
o
HOOK_REVIEW_RESULT=fail
"

if command -v oc >/dev/null 2>&1; then
    "$timeout_cmd" "$hook_timeout_seconds" oc "$prompt" | tee "$tmp_output"
    status=${PIPESTATUS[0]}
else
    "$timeout_cmd" "$hook_timeout_seconds" opencode run "$prompt" | tee "$tmp_output"
    status=${PIPESTATUS[0]}
fi

last_non_empty_line=$(awk 'NF { line=$0 } END { print line }' "$tmp_output")

if [ "$status" -ne 0 ]; then
    echo ""
    echo "❌ Pre-commit rechazado. Corrige los errores antes de commitir."
    exit 1
fi

if [ "$last_non_empty_line" != "HOOK_REVIEW_RESULT=pass" ]; then
    echo ""
    echo "❌ Pre-commit rechazado. Falta marcador final HOOK_REVIEW_RESULT=pass."
    exit 1
fi

echo ""
echo "✅ Pre-commit aprobado"
HOOK
        chmod +x "${target_dir}/.git/hooks/pre-commit"
        success "Git hook configurado en ${target_dir}/.git/hooks/pre-commit"
        cat > "${target_dir}/.git/hooks/pre-push" << 'HOOK'
#!/bin/bash

echo ""
echo "🔍 OpenCode Pre-Push Review"
echo "============================"

tmp_output=$(mktemp)
trap 'rm -f "$tmp_output"' EXIT

hook_timeout_seconds="${OC_HOOK_TIMEOUT_SECONDS:-60}"
if command -v timeout >/dev/null 2>&1; then
    timeout_cmd="timeout"
elif command -v gtimeout >/dev/null 2>&1; then
    timeout_cmd="gtimeout"
else
    echo ""
    echo "❌ Pre-push rechazado. No se encontró timeout/gtimeout para limitar la revisión."
    exit 1
fi

if upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null); then
    diff_context=$(git diff --name-status "$upstream"..HEAD && printf '\n' && git diff --stat "$upstream"..HEAD)
else
    diff_context=$(git log --oneline -10 2>/dev/null; printf '\n'; git diff --name-status HEAD~1..HEAD 2>/dev/null; printf '\n'; git diff --stat HEAD~1..HEAD 2>/dev/null)
fi

if [ -z "$diff_context" ]; then
    diff_context="No hay diff de push disponible. Revisa el estado Git si aplica."
fi

if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks detect --verbose; then
        echo ""
        echo "❌ Pre-push rechazado. gitleaks detectó posibles secretos."
        exit 1
    fi
else
    echo "⚠️  gitleaks no está instalado; se omite escaneo local de secretos."
fi

if [ "${OC_HOOK_LLM:-0}" != "1" ]; then
    echo "ℹ️  Revisión LLM omitida (actívala con OC_HOOK_LLM=1)."
    echo "✅ Pre-push aprobado"
    exit 0
fi

prompt="Revisión pre-push metadata-only.

No uses agentes, herramientas, bash, grep, git ni lecturas de archivos.
Usa únicamente la metadata incluida abajo. No intentes inspeccionar el repositorio.

Antes de hacer push, verifica:
1. Secretos en código
2. Credenciales hardcodeadas
3. Tokens API expuestos
4. Configuración insegura

Contexto de cambios para push (metadata: name-status + stat; no patch body):
$diff_context

Si encuentra algo crítico, rechaza el push.

La última línea no vacía de tu respuesta debe ser exactamente HOOK_REVIEW_RESULT=pass o HOOK_REVIEW_RESULT=fail.

Termina con una línea final exacta, sin texto después:
HOOK_REVIEW_RESULT=pass
o
HOOK_REVIEW_RESULT=fail
"

if command -v oc >/dev/null 2>&1; then
    "$timeout_cmd" "$hook_timeout_seconds" oc "$prompt" | tee "$tmp_output"
    status=${PIPESTATUS[0]}
else
    "$timeout_cmd" "$hook_timeout_seconds" opencode run "$prompt" | tee "$tmp_output"
    status=${PIPESTATUS[0]}
fi

last_non_empty_line=$(awk 'NF { line=$0 } END { print line }' "$tmp_output")

if [ "$status" -ne 0 ]; then
    echo ""
    echo "❌ Pre-push rechazado. Seguridad comprometida."
    exit 1
fi

if [ "$last_non_empty_line" != "HOOK_REVIEW_RESULT=pass" ]; then
    echo ""
    echo "❌ Pre-push rechazado. Falta marcador final HOOK_REVIEW_RESULT=pass."
    exit 1
fi

echo ""
echo "✅ Pre-push aprobado"
HOOK
        chmod +x "${target_dir}/.git/hooks/pre-push"
        success "Git hook configurado en ${target_dir}/.git/hooks/pre-push"
    else
        warn "${target_dir} no es un repo Git; se omiten hooks pre-commit/pre-push."
    fi

    # Auto-install skills for detected stack
    info "Detectando stack e instalando skills..."
    install_skills_for_stacks "$target_dir"

    success "Proyecto inicializado en ${opencode_dir}/"
}

run_interactive() {
    check_fzf
    local choice
    choice=$(show_menu | fzf --height=14 --border --prompt="Selecciona: " | awk '{print $1}')

    case "$choice" in
        a) run_agent "architect" "Analiza el proyecto actual sin modificar" ;;
        p)
            read -rp "Tarea: " task
            run_agent "planner" "Divide esta tarea en fases: $task"
            ;;
        b)
            read -rp "Cambio a implementar: " cambio
            run_agent "builder" "Implementa este cambio: $cambio"
            ;;
        r) run_agent "reviewer" "Revisa los cambios realizados" ;;
        s) run_agent "security-auditor" "Audita seguridad del proyecto actual" ;;
        d) run_agent "docs-writer" "Genera/actualiza documentación del proyecto" ;;
