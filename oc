## DescripciГіn
Describe tu proyecto aquГ­.

## Stack TecnolГіgico
- ...

## Comandos
```bash
npm install
npm test
npm run build
```

## Estructura
```
.
в”њв”Ђв”Ђ src/
в”њв”Ђв”Ђ tests/
в””в”Ђв”Ђ ...
```

## Notas
- ConfiguraciГіn especГ­fica del proyecto
- Convenciones
- Contacto del equipo
EOF

    cat > "${target_dir}/.git/hooks/pre-commit" << 'HOOK'
#!/bin/bash
echo "Ejecutando revisiГіn pre-commit..."
opencode -p "Ejecuta @reviewer con precommit-review. Revisa los archivos modificados. No modifiques nada."
HOOK
    chmod +x "${target_dir}/.git/hooks/pre-commit"

    success "Proyecto inicializado en ${opencode_dir}/"
    success "Git hook configurado en ${target_dir}/.git/hooks/pre-commit"
}

memory_search() {
    if [ ! -d "${OC_MEMORY}" ]; then
        mkdir -p "${OC_MEMORY}"
        warn "Memory bank vacГ­o. Creado ${OC_MEMORY}/"
        return 0
    fi

    local query="$*"
    if [ -z "$query" ]; then
        echo "Archivos en memory bank:"
        ls -la "${OC_MEMORY}/"
        return 0
    fi

    echo -e "${BLUE}Buscando en memory bank...${NC}"
    grep -rli "$query" "${OC_MEMORY}/" 2>/dev/null || echo "No encontrado"
}

memory_save() {
    local context="$1"
    local timestamp
    timestamp=$(date +%Y%m%d-%H%M%S)
    mkdir -p "${OC_MEMORY}"
    printf -- '---\nFecha: %s\nContexto: %s\n---\n\n' "$(date)" "$context" >> "${OC_MEMORY}/${timestamp}.md"
    success "Guardado en ${OC_MEMORY}/${timestamp}.md"
}

run_interactive() {
    check_fzf
    local choice
    choice=$(show_menu | fzf --height=14 --border --prompt="Selecciona: " | awk '{print $1}')

    case "$choice" in
        a) run_agent "architect" "Analiza el proyecto actual sin modificar" ;;
        p)
            read -rp "Tarea: " task
            run_agent "planner" "Divide esta tarea en fases: $task"
            ;;
        b)
            read -rp "Cambio a implementar: " cambio
            run_agent "builder" "Implementa este cambio: $cambio"
            ;;
        r) run_agent "reviewer" "Revisa los cambios realizados" ;;
        s) run_agent "security-auditor" "Audita seguridad del proyecto actual" ;;
        d) run_agent "docs-writer" "Genera/actualiza documentaciГіn del proyecto" ;;
        v)
            read -rp "DescripciГіn DevOps: " desc
            run_agent "devops" "Tarea DevOps: $desc"
            ;;
        o) run_agent "oncall" "Diagnostica problema en producciГіn" ;;
        w) run_wizard ;;
        i) run_init "$(pwd)" ;;
        m)
            read -rp "Query: " query
            search_memory "$query"
            ;;
        q) exit 0 ;;
    esac
}

