# Real entropy: od is POSIX — works on Linux and macOS without xxd
generate_obs_id() {
    local rand
    rand=$(od -An -N4 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n\t') \
        || rand=$(printf '%08x' $(( (RANDOM << 16) | RANDOM )))
    printf '%s-%s' "$(date +%Y%m%d-%H%M%S)" "$rand"
}

create_observation() {
    local type="${1:-note}"
    local content="$2"
    local project="${3:-global}"
    local obs_id
    obs_id=$(generate_obs_id)

    if [ -z "$content" ]; then
        echo "Error: content is required"
        return 1
    fi

    if ! command -v python3 >/dev/null 2>&1; then
        echo "Error: python3 is required to create observations"
        return 1
    fi

    local obs_dir="${OC_MEMORY}/projects/${project}"
    mkdir -p "$obs_dir"

    local obs_file="${obs_dir}/${obs_id}.md"
    local yaml_project yaml_type yaml_summary
    yaml_project=$(yaml_quote "$project")
    yaml_type=$(yaml_quote "$type")
    yaml_summary=$(yaml_quote "${content:0:100}")

    cat > "$obs_file" << EOF
---
id: obs_${obs_id}
date: $(date +%Y-%m-%d\ %H:%M:%S)
project: ${yaml_project}
type: ${yaml_type}
summary: ${yaml_summary}
tokens_est: 200
---

${content}
EOF

    echo "$obs_id" > "${OC_MEMORY}/.last_obs_id"

    # Sync to project's docs/memory/ for portability
    sync_to_project_docs "$project" "$obs_file" "observation"

    success "Observation created: obs_${obs_id}"

    # Append to markdown INDEX
    if grep -q "^<!-- INDEX_START -->" "${OC_MEMORY}/INDEX.md" 2>/dev/null; then
        echo "obs_${obs_id} | $(date +%Y-%m-%d) | ${project} | ${type} | ${content:0:80}" >> "${OC_MEMORY}/INDEX.md"
    fi

    # Append to JSONL index for fast querying with jq/fzf/ripgrep
    local jsonl_index="${OC_MEMORY}/index.jsonl"
    python3 - "$jsonl_index" "obs_${obs_id}" "$(date +%Y-%m-%dT%H:%M:%S)" "$project" "$type" "${content:0:100}" "memory/projects/${project}/${obs_id}.md" << 'PYEOF'
import json, sys
path, obs_id, date, project, obs_type, summary, obs_path = sys.argv[1:]
with open(path, "a", encoding="utf-8") as fh:
    fh.write(json.dumps({
        "id": obs_id,
        "date": date,
        "project": project,
        "type": obs_type,
        "summary": summary,
        "path": obs_path,
    }, ensure_ascii=False) + "\n")
PYEOF
}

normalize_obs_id() {
    local obs_id="$1"
    obs_id="${obs_id#obs_}"
    printf '%s' "$obs_id"
}

trim_field() {
    local value="$1"
    value="${value#${value%%[![:space:]]*}}"
    value="${value%${value##*[![:space:]]}}"
    printf '%s' "$value"
}

yaml_quote() {
    python3 -c 'import json, sys; print(json.dumps(sys.argv[1], ensure_ascii=False))' "$1"
}

frontmatter_value() {
    local file="$1"
    local key="$2"
    local line value
    line=$(grep -m1 "^${key}:" "$file" 2>/dev/null || true)
    value="${line#*:}"
    value="${value# }"
    value="${value%\"}"
    value="${value#\"}"
    value="${value%\'}"
    value="${value#\'}"
    printf '%s' "$value"
}

search_memory() {
    local query="${1:-}"
    local project="${2:-}"
    local type="${3:-}"

    if [ -z "$query" ]; then
        echo "Usage: oc --memory <query> [-p project] [-t type]"
        return 0
    fi

    if [ ! -f "${OC_MEMORY}/INDEX.md" ]; then
        warn "No memory index found. Use oc --remember to add observations."
        return 0
    fi

    local results count=0
    while IFS= read -r line; do
        local line_id line_date line_project line_type line_summary
        IFS='|' read -r line_id line_date line_project line_type line_summary <<< "$line"
        line_project=$(trim_field "$line_project")
        line_type=$(trim_field "$line_type")
        [ -n "$project" ] && [ "$line_project" != "$project" ] && continue
        [ -n "$type" ] && [ "$line_type" != "$type" ] && continue
        results+="${line}"$'\n'
        count=$((count + 1))
        [ "$count" -ge 20 ] && break
    done < <(grep -F -i -- "$query" "${OC_MEMORY}/INDEX.md" 2>/dev/null)

    if [ -z "$results" ]; then
        echo "No results found for: $query"
        return 0
    fi

    echo -e "${BLUE}=== Memory Search Results ===${NC}"
    while IFS= read -r line; do
        echo "$line"
    done <<< "$results"
    echo ""
    echo "Use --timeline <obs_id> for context or --get <id1,id2> for full details."
}

get_observations() {
    local ids="${1:-}"

    if [ -z "$ids" ]; then
        echo "Usage: oc --get <obs_id1,obs_id2,...>"
        return 0
    fi

    IFS=',' read -ra OBS_IDS <<< "$ids"

    for obs_id in "${OBS_IDS[@]}"; do
        obs_id=$(echo "$obs_id" | tr -d ' ')
        obs_id=$(normalize_obs_id "$obs_id")
        local obs_file
        obs_file=$(find "${OC_MEMORY}" -name "${obs_id}.md" 2>/dev/null | head -1)

        if [ -z "$obs_file" ]; then
            warn "Observation not found: $obs_id"
            continue
        fi

        echo -e "${BLUE}=== obs_${obs_id} ===${NC}"
        cat "$obs_file"
        echo ""
    done
}

get_timeline() {
    local obs_id="${1:-}"

    if [ -z "$obs_id" ]; then
        echo "Usage: oc --timeline <obs_id>"
        return 0
    fi

    local obs_file
    obs_id=$(normalize_obs_id "$obs_id")
    obs_file=$(find "${OC_MEMORY}" -name "${obs_id}.md" 2>/dev/null | head -1)

    if [ -z "$obs_file" ]; then
        warn "Observation not found: $obs_id"
        return 0
    fi

    local obs_dir
    obs_dir=$(dirname "$obs_file")

    echo -e "${BLUE}=== Timeline around $obs_id ===${NC}"
    while IFS= read -r f; do
        local fname summary fdate
        fname=$(basename "$f" .md)
        summary=$(frontmatter_value "$f" "summary")
        fdate=$(frontmatter_value "$f" "date")
        echo "$fname | $fdate | ${summary:0:80}"
    done < <(ls -t "$obs_dir"/*.md 2>/dev/null | head -5)
}

