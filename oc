        o) run_agent "oncall" "Diagnostica problema en producción" ;;
        w) run_wizard ;;
        i) run_init "$(pwd)" ;;
        m)
            read -rp "Query: " query
            search_memory "$query"
            ;;
        q) exit 0 ;;
    esac
}

