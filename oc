#!/usr/bin/env bash

OC_CONFIG="${HOME}/.config/opencode"
OC_BIN="${HOME}/.local/bin"
OC_MEMORY="${OC_CONFIG}/memory"
OC_PROFILES="${OC_CONFIG}/profiles"
CURRENT_PROFILE="${OC_CONFIG}/.current_profile"

OC_BUDGET_FILE="${OC_CONFIG}/.budget"
OC_SESSION_FILE="${OC_CONFIG}/.session"
OC_LAST_COMMANDS_FILE="${OC_CONFIG}/.last_commands"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[OK]${NC} $1"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $1"; }
error()   { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

track_turn() {
    local turns=1
    mkdir -p "${OC_CONFIG}"
    if [ -f "${OC_SESSION_FILE}" ]; then
        local current
        current=$(cat "${OC_SESSION_FILE}" 2>/dev/null || printf '0')
        if [[ "$current" =~ ^[0-9]+$ ]]; then
            turns=$((current + 1))
        fi
    fi
    echo "$turns" > "${OC_SESSION_FILE}"
    if [ "$turns" -gt 20 ]; then
        warn "Session turns: $turns (consider context compaction)"
    fi

    # Self-Improvement: track outcomes and reflect periodically (inline to avoid forward-call issues)
    if [ "${turns}" -gt 0 ] && [ $((turns % 5)) -eq 0 ]; then
        local _track_project="$(detect_project 2>/dev/null || echo 'unknown')"
        local _track_outdir="${OC_MEMORY}/outcomes"
        mkdir -p "$_track_outdir"
        local _track_ts=$(date +%Y%m%d-%H%M%S)
        python3 - "${_track_outdir}/interaction-${_track_ts}.json" "interaction" "active" "$_track_project" "Session turn ${turns}" << 'PYEOF'
import json, sys
path, workflow, status, project, details = sys.argv[1:]
with open(path, "w") as f:
    json.dump({"workflow": workflow, "status": status, "project": project, "details": details, "date": sys.argv[5] if len(sys.argv) > 5 else ""}, f, ensure_ascii=False)
PYEOF
    fi
    if [ "${turns}" -gt 0 ] && [ $((turns % 15)) -eq 0 ]; then
        create_observation "note" "periodic self-check at turn ${turns}" "$_track_project"
    fi

    # Octogent-inspired: mid-session reflection at turn 20
    if [ "${turns}" -eq 20 ]; then
        local _ref_prj="$(detect_project 2>/dev/null || echo 'global')"
        create_observation "reflection" "mid-session check at turn 20 for ${_ref_prj}" "$_ref_prj"
        echo ""
        info "Mid-session reflection: consider 'oc --compact' if context feels heavy"
    fi
}

check_budget() {
    local turns=0
    [ -f "${OC_SESSION_FILE}" ] && turns=$(cat "${OC_SESSION_FILE}")
    if [ "$turns" -gt 50 ]; then
        warn "High session turns ($turns). Context may need compaction."
    fi
}

# Octogent-inspired: detect if agent is looping on same operation (SC1087 compliance)
detect_loop() {
    local current_cmd="${1:-}"
    [ -z "$current_cmd" ] && return 0

    mkdir -p "${OC_CONFIG}"
    local loop_history="${OC_CONFIG}/.loop_history"

    local count=0
    if [ -f "$loop_history" ]; then
        count=$(grep -c "^${current_cmd}$" "$loop_history" 2>/dev/null | tr -d '[:space:]' || echo "0")
        count="${count:-0}"
    fi

    echo "$current_cmd" >> "$loop_history"

    local window=6
    if [ -f "$loop_history" ] && [ -s "$loop_history" ]; then
        tail -n "$window" "$loop_history" > "${loop_history}.tmp" 2>/dev/null && mv "${loop_history}.tmp" "$loop_history"
    fi

    if [ "$count" -ge 3 ]; then
        return 1
    fi
    return 0
}

warn_if_looping() {
    local cmd_sig="${1:-}"
    [ -z "$cmd_sig" ] && return 0

    if ! detect_loop "$cmd_sig"; then
        warn "Possible loop detected: '$cmd_sig' repeated 3+ times"
        echo "  Hint: oc --compact to reset session, or oc --remember to save progress"
    fi
}

# Only require opencode at startup; fzf checked on demand
check_deps() {
