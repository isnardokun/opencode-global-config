list_workflows() {
    echo "Available workflows:"
    echo "  bug-hunt      - Find and fix bugs (5 phases, single-pass)"
    echo "  new-project   - Setup new project (4 phases, single-pass)"
    echo "  debug         - Debug production issue (3 phases, single-pass)"
    echo "  document      - Generate documentation (3 phases, single-pass)"
    echo "  feature       - Develop a feature (4 phases, single-pass)"
}

if [ $# -eq 0 ]; then
    opencode
    exit 0
fi

case "$1" in
    -w|--wizard)
        run_wizard
        ;;
    -i|--interactive)
        run_interactive
        ;;
    --init)
        run_init "${2:-.}"
        ;;
    -t|--type)
        shift
        _type="$1"
        shift
        search_memory "$*" "" "$_type"
        ;;
    --timeline)
        get_timeline "$2"
        ;;
    --get)
        get_observations "$2"
        ;;
    --capture)
        capture_session
        ;;
    --remember)
        shift
        _type="note"
        if [ "${1:-}" == "-t" ]; then
            shift
            _type="$1"
            shift
        fi
        create_observation "$_type" "$*"
        ;;
    --memory)
        shift
        if [ "${1:-}" == "--timeline" ]; then
            get_timeline "$2"
        elif [ "${1:-}" == "--get" ]; then
            get_observations "$2"
        elif [ "${1:-}" == "-t" ]; then
            shift
            _type="$1"
            shift
            search_memory "$*" "" "$_type"
        else
            search_memory "$1" "${2:-}" "${3:-}"
        fi
        ;;
    -p|--profile)
        switch_profile "$2"
        ;;
    -l|--list-profiles)
        list_profiles
        ;;
    -h|--help)
        show_help
        ;;
    --compact)
        echo "0" > "${OC_SESSION_FILE}"
        success "Turn counter reset to 0."
        warn "For long sessions, manually summarize key context before continuing."
        ;;
    --budget)
        show_budget
        ;;
    --workflow)
        shift
        _wf_name="${1:-}"
        shift
        _wf_interactive="false"
        _wf_feature=""
        _wf_target="."
        # feature workflow takes description as first arg, path as second
        if [ "$_wf_name" = "feature" ]; then
            _wf_feature="${1:-nueva funcionalidad}"
            shift
            _wf_target="${1:-.}"
            shift
        else
            _wf_target="${1:-.}"
            shift
        fi
        [ "${1:-}" = "--interactive" ] && _wf_interactive="true"
        run_workflow "$_wf_name" "$_wf_target" "$_wf_interactive" "$_wf_feature"
        ;;
    --list-workflows)
        list_workflows
        ;;
    analyze)
        quick_analyze "${2:-.}"
        ;;
    plan)
        quick_plan "$2"
        ;;
    build)
        shift
        quick_build "$*"
        ;;
    review)
        quick_review
        ;;
    secure)
        quick_secure
        ;;
    docs)
        quick_docs
        ;;
    devops)
        shift
        quick_devops "$*"
        ;;
    oncall)
        quick_oncall
        ;;
    *)
        _oc_run -p "$*"
        ;;
esac
