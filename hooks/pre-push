#!/bin/bash

echo ""
echo "🔍 OpenCode Pre-Push Review"
echo "============================"

tmp_output=$(mktemp)
trap 'rm -f "$tmp_output"' EXIT

hook_timeout_seconds="${OC_HOOK_TIMEOUT_SECONDS:-60}"
if command -v timeout >/dev/null 2>&1; then
    timeout_cmd="timeout"
elif command -v gtimeout >/dev/null 2>&1; then
    timeout_cmd="gtimeout"
else
    echo ""
    echo "❌ Pre-push rechazado. No se encontró timeout/gtimeout para limitar la revisión."
    exit 1
fi

if upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null); then
    diff_context=$(git diff --name-status "$upstream"..HEAD && printf '\n' && git diff --stat "$upstream"..HEAD)
else
    diff_context=$(git log --oneline -10 2>/dev/null; printf '\n'; git diff --name-status HEAD~1..HEAD 2>/dev/null; printf '\n'; git diff --stat HEAD~1..HEAD 2>/dev/null)
fi

if [ -z "$diff_context" ]; then
    diff_context="No hay diff de push disponible. Revisa el estado Git si aplica."
fi

if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks detect --verbose; then
        echo ""
        echo "❌ Pre-push rechazado. gitleaks detectó posibles secretos."
        exit 1
    fi
fi

prompt="
Usa @security-auditor.

Antes de hacer push, verifica:
1. Secretos en código
2. Credenciales hardcodeadas
3. Tokens API expuestos
4. Configuración insegura

Contexto de cambios para push (metadata: name-status + stat; no patch body):
$diff_context

Si encuentra algo crítico, rechaza el push.

La última línea no vacía de tu respuesta debe ser exactamente HOOK_REVIEW_RESULT=pass o HOOK_REVIEW_RESULT=fail.

Termina con una línea final exacta, sin texto después:
HOOK_REVIEW_RESULT=pass
o
HOOK_REVIEW_RESULT=fail
"

if command -v oc >/dev/null 2>&1; then
    "$timeout_cmd" "$hook_timeout_seconds" oc "$prompt" | tee "$tmp_output"
    status=${PIPESTATUS[0]}
else
    "$timeout_cmd" "$hook_timeout_seconds" opencode run "$prompt" | tee "$tmp_output"
    status=${PIPESTATUS[0]}
fi

last_non_empty_line=$(awk 'NF { line=$0 } END { print line }' "$tmp_output")

if [ "$status" -ne 0 ]; then
    echo ""
    echo "❌ Pre-push rechazado. Seguridad comprometida."
    exit 1
fi

if [ "$last_non_empty_line" != "HOOK_REVIEW_RESULT=pass" ]; then
    echo ""
    echo "❌ Pre-push rechazado. Falta marcador final HOOK_REVIEW_RESULT=pass."
    exit 1
fi

echo ""
echo "✅ Pre-push aprobado"
