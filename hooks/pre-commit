#!/bin/bash

echo ""
echo "🔍 OpenCode Pre-Commit Review"
echo "=============================="

tmp_output=$(mktemp)
trap 'rm -f "$tmp_output"' EXIT

hook_timeout_seconds="${OC_HOOK_TIMEOUT_SECONDS:-60}"
if command -v timeout >/dev/null 2>&1; then
    timeout_cmd="timeout"
elif command -v gtimeout >/dev/null 2>&1; then
    timeout_cmd="gtimeout"
else
    echo ""
    echo "❌ Pre-commit rechazado. No se encontró timeout/gtimeout para limitar la revisión."
    exit 1
fi

diff_context=$(git diff --cached --name-status && printf '\n' && git diff --cached --stat)
if [ -z "$diff_context" ]; then
    diff_context="No hay diff staged disponible. Revisa el estado Git si aplica."
fi

if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --verbose; then
        echo ""
        echo "❌ Pre-commit rechazado. gitleaks detectó posibles secretos."
        exit 1
    fi
else
    echo "⚠️  gitleaks no está instalado; se omite escaneo local de secretos."
fi

if [ "${OC_HOOK_LLM:-0}" != "1" ]; then
    echo "ℹ️  Revisión LLM omitida (actívala con OC_HOOK_LLM=1)."
    echo "✅ Pre-commit aprobado"
    exit 0
fi

prompt="
Revisión pre-commit metadata-only.

No uses agentes, herramientas, bash, grep, git ni lecturas de archivos.
Usa únicamente la metadata incluida abajo. No intentes inspeccionar el repositorio.

Revisa los archivos modificados en este commit usando solo metadata.

Metadata staged (name-status + stat; no patch body):
$diff_context

Reglas:
- No modifiques archivos.
- Reporta solo hallazgos.
- Si hay errores críticos, el commit será rechazado.
- La última línea no vacía de tu respuesta debe ser exactamente HOOK_REVIEW_RESULT=pass o HOOK_REVIEW_RESULT=fail.

Resumen esperado:
1. Archivos modificados
2. Hallazgos críticos (bloqueantes)
3. Hallazgos medios
4. Pruebas ejecutadas
5. Recomendación: aprobar/corregir

Termina con una línea final exacta, sin texto después:
HOOK_REVIEW_RESULT=pass
o
HOOK_REVIEW_RESULT=fail
"

if command -v oc >/dev/null 2>&1; then
    "$timeout_cmd" "$hook_timeout_seconds" oc "$prompt" | tee "$tmp_output"
    status=${PIPESTATUS[0]}
else
    "$timeout_cmd" "$hook_timeout_seconds" opencode run "$prompt" | tee "$tmp_output"
    status=${PIPESTATUS[0]}
fi

last_non_empty_line=$(awk 'NF { line=$0 } END { print line }' "$tmp_output")

if [ "$status" -ne 0 ]; then
    echo ""
    echo "❌ Pre-commit rechazado. Corrige los errores antes de commitir."
    exit 1
fi

if [ "$last_non_empty_line" != "HOOK_REVIEW_RESULT=pass" ]; then
    echo ""
    echo "❌ Pre-commit rechazado. Falta marcador final HOOK_REVIEW_RESULT=pass."
    exit 1
fi

echo ""
echo "✅ Pre-commit aprobado"
