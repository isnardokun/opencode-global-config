{
  "name": "auto",
  "description": "Assisted mode — conservative permissions with extra decision tracking",
  "opencode": {
    "permission": {
      "read": "allow",
      "list": "allow",
      "glob": "allow",
      "grep": "allow",
      "edit": "ask",
      "bash": "ask",
      "webfetch": "ask",
      "websearch": "ask"
    }
  },
  "policy": {
    "maxFilesPerIteration": 5,
    "allowEnvEdit": false,
    "requireSecurityReview": true,
    "trackDecisions": true
  }
}
