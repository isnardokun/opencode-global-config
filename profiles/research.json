{
  "name": "research",
  "description": "Research and exploration mode — broad reading, no secrets, no env edits",
  "opencode": {
    "permission": {
      "read": "allow",
      "list": "allow",
      "glob": "allow",
      "grep": "allow",
      "edit": "ask",
      "bash": "ask",
      "webfetch": "allow",
      "websearch": "allow"
    }
  },
  "policy": {
    "maxFilesPerIteration": 10,
    "allowEnvEdit": false,
    "requireExplanation": true
  }
}
