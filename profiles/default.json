{
  "name": "default",
  "description": "General development — edits and bash require confirmation",
  "opencode": {
    "permission": {
      "read": "allow",
      "list": "allow",
      "glob": "allow",
      "grep": "allow",
      "edit": "ask",
      "bash": "ask",
      "webfetch": "ask",
      "websearch": "ask"
    }
  },
  "policy": {
    "maxFilesPerIteration": 3,
    "allowEnvEdit": false,
    "requireTests": true,
    "requireExplanation": true,
    "requireDiffReview": true
  }
}
