{
  "name": "review",
  "description": "Review mode — read and report, no destructive changes",
  "opencode": {
    "permission": {
      "read": "allow",
      "list": "allow",
      "glob": "allow",
      "grep": "allow",
      "edit": "deny",
      "bash": "ask",
      "webfetch": "deny",
      "websearch": "deny"
    }
  },
  "policy": {
    "maxFilesPerIteration": 15,
    "allowEnvEdit": false,
    "requireExplanation": true,
    "reportOnly": true
  }
}
