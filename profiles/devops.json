{
  "name": "devops",
  "description": "Infrastructure mode — deployments, rollbacks, and config changes",
  "opencode": {
    "permission": {
      "read": "allow",
      "list": "allow",
      "glob": "allow",
      "grep": "allow",
      "edit": "allow",
      "bash": "allow",
      "webfetch": "allow",
      "websearch": "allow"
    }
  },
  "policy": {
    "maxFilesPerIteration": 20,
    "allowEnvEdit": true,
    "requireSecurityReview": true,
    "requireCheckpoint": true,
    "documentAllChanges": true
  }
}
