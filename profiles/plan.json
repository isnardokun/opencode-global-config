{
  "name": "plan",
  "description": "Planning mode — read and analyze only, no modifications",
  "opencode": {
    "permission": {
      "read": "allow",
      "list": "allow",
      "glob": "allow",
      "grep": "allow",
      "edit": "deny",
      "bash": "deny",
      "webfetch": "ask",
      "websearch": "ask"
    }
  },
  "policy": {
    "maxFilesPerIteration": 10,
    "allowEnvEdit": false,
    "requireExplanation": true,
    "reportOnly": true
  }
}
