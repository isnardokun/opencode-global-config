{
  "name": "trusted",
  "description": "Advanced developer — direct edits with rollback safeguards enforced",
  "opencode": {
    "permission": {
      "read": "allow",
      "list": "allow",
      "glob": "allow",
      "grep": "allow",
      "edit": "allow",
      "bash": "allow",
      "webfetch": "allow",
      "websearch": "allow"
    }
  },
  "policy": {
    "maxFilesPerIteration": 10,
    "allowEnvEdit": false,
    "requireTests": true,
    "requireRollback": true,
    "checkpointBeforeChanges": true
  }
}
