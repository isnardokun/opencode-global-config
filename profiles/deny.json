{
  "name": "deny",
  "description": "Read-only analysis mode — no file edits, no command execution",
  "opencode": {
    "permission": {
      "read": "allow",
      "list": "allow",
      "glob": "allow",
      "grep": "allow",
      "edit": "deny",
      "bash": "deny",
      "webfetch": "deny",
      "websearch": "deny"
    }
  },
  "policy": {
    "maxFilesPerIteration": 5,
    "allowEnvEdit": false,
    "reportOnly": true
  }
}
